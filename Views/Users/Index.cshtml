@model List<HelpdeskApp.Models.User>
@{
    ViewData["Title"] = "Users";
}

<div class="page-header">
    <div>
        <h4 class="page-title">Team Members</h4>
        <p class="page-subtitle">Manage your support agents and access control.</p>
    </div>
    <a href="@Url.Action("Create")" class="btn-coral">
        <i class="bi bi-plus-lg"></i> New User
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th>Joined</th>
                        <th style="width:100px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr><td colspan="5">
                            <div class="empty-state">
                                <i class="bi bi-people"></i>
                                <p>No users found yet.</p>
                            </div>
                        </td></tr>
                    }
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div style="width:38px;height:38px;border-radius:50%;background:var(--green-dark);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:0.75rem;flex-shrink:0;">
                                        @{
                                            var parts = user.FullName.Split(' ');
                                            var i = parts.Length >= 2
                                                ? parts[0].Substring(0,1).ToUpper() + parts[^1].Substring(0,1).ToUpper()
                                                : user.FullName.Substring(0,1).ToUpper();
                                        }
                                        @i
                                    </div>
                                    <div>
                                        <div style="font-weight:700;color:var(--dark);font-size:0.9rem;">@user.FullName</div>
                                        <div style="font-size:0.78rem;color:var(--text-light);">ID: @user.Id</div>
                                    </div>
                                </div>
                            </td>
                            <td style="color:var(--text-muted);font-size:0.88rem;">@user.Email</td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge-status badge-active">Active</span>
                                }
                                else
                                {
                                    <span class="badge-status badge-inactive">Inactive</span>
                                }
                            </td>
                            <td style="color:var(--text-muted);font-size:0.85rem;">@user.CreatedDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <form asp-action="ToggleActive" asp-route-id="@user.Id" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    @if (user.IsActive)
                                    {
                                        <button type="submit" class="btn-ghost" title="Deactivate" style="color:var(--coral);">
                                            <i class="bi bi-toggle-on" style="font-size:1.2rem;"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn-ghost" title="Activate">
                                            <i class="bi bi-toggle-off" style="font-size:1.2rem;"></i>
                                        </button>
                                    }
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
