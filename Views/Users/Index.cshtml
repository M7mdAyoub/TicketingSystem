@model List<HelpdeskApp.Models.User>
@using HelpdeskApp.Data
@{
    ViewData["Title"] = "Users";
    var lang = Context.Request.Cookies["lang"] ?? "en";
    var token = Html.AntiForgeryToken().ToString();
    var tokenValue = System.Text.RegularExpressions.Regex.Match(token, "value=\"([^\"]+)\"").Groups[1].Value;
}

<div class="page-header">
    <div>
        <h4 class="page-title">@Lang.T("users", lang)</h4>
        <p class="page-subtitle">@(lang == "ar" ? "إدارة أعضاء فريقك وحالة وصولهم." : "Manage your organization's team members and their access status.")</p>
    </div>
    <button type="button" class="btn-coral" onclick="openUserModal()">
        <i class="bi bi-person-plus me-1"></i> @Lang.T("create_new_user", lang)
    </button>
</div>

@if (Model.Count == 0)
{
    <div class="card" id="emptyUsers">
        <div class="empty-state">
            <i class="bi bi-people"></i>
            <p>@(lang == "ar" ? "لم يتم العثور على مستخدمين." : "No users found yet.")</p>
        </div>
    </div>
}

<div class="row g-4" id="usersGrid">
    @foreach (var user in Model)
    {
        <div class="col-md-6 col-lg-3">
            <div class="card ui-st-2de8ef" >
                <div class="user-status-badge badge-pos-@lang">
                    <form class="d-inline" asp-action="ToggleActive" asp-route-id="@user.Id" method="post" >
                        @Html.AntiForgeryToken()
                        @if (user.IsActive)
                        {
                            <button class="ui-st-75d3a3" type="submit"  title="@Lang.T("active", lang)">
                                <span class="ui-st-997d76" >@Lang.T("active", lang)</span>
                                <div class="ui-st-a179fa" >
                                    <div class="ui-st-118d23" ></div>
                                </div>
                            </button>
                        }
                        else
                        {
                            <button class="ui-st-897909" type="submit"  title="@Lang.T("inactive", lang)">
                                <span class="ui-st-9e8798" >@Lang.T("inactive", lang)</span>
                                <div class="ui-st-5b4c9e" >
                                    <div class="ui-st-0e9080" ></div>
                                </div>
                            </button>
                        }
                    </form>
                </div>

                <div class="ui-st-3cee86" >
                    <div class="ui-st-79535c" >
                        @{
                            var parts = user.FullName.Split(' ');
                            var initials = parts.Length >= 2
                                ? parts[0].Substring(0,1).ToUpper() + parts[^1].Substring(0,1).ToUpper()
                                : user.FullName.Substring(0,1).ToUpper();
                        }
                        @initials
                    </div>
                    @if (user.IsActive)
                    {
                        <div class="ui-st-4c1056" ></div>
                    }
                </div>

                <h5 class="ui-st-b289d9" >@user.FullName</h5>
                <div class="ui-st-2c0a02" >@(lang == "ar" ? "عضو في الفريق" : "Team Member")</div>
                <div class="ui-st-6f22b7" >@user.Email</div>

                <div class="d-flex justify-content-center gap-2">
                    <div class="ui-st-c7eec0" style="cursor: pointer;" onclick="openEmailUserModal('@user.Email')" title="@Lang.T("email", lang)">
                        <i class="bi bi-envelope"></i>
                    </div>
                    <div class="ui-st-5f46a9" style="cursor: pointer;" onclick="openEditUserModal('@user.Id', '@user.FullName.Replace("'", "\\'")', '@user.Email', @user.IsActive.ToString().ToLower())" title="@(lang == "ar" ? "تعديل" : "Edit")">
                        <i class="bi bi-three-dots-vertical"></i>
                    </div>
                </div>
            </div>
        </div>
    }
</div>


<div class="ui-st-fed104" id="userModal"  onclick="if(event.target===this)closeUserModal()">
    <div class="ui-st-0a26e7" >
        <div class="ui-st-87d288" >
            <h3 class="ui-st-dcc926" >@Lang.T("create_new_user", lang)</h3>
            <button class="ui-st-5a2acb" onclick="closeUserModal()" >
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="ui-st-36b319" id="userModalError" >
        </div>

        <form id="userForm" data-url="@Url.Action("CreateAjax", "Users")" data-token="@tokenValue" data-txt-active="@Lang.T("active", lang)" data-txt-inactive="@Lang.T("inactive", lang)" data-txt-team="@(lang == "ar" ? "عضو في الفريق" : "Team Member")" data-txt-email="@Lang.T("email", lang)" data-txt-more="@(lang == "ar" ? "خيارات أخرى" : "More Options")" data-lang="@lang">
            <div class="mb-3">
                <label class="form-label">@Lang.T("full_name", lang)</label>
                <input type="text" id="userFullName" class="form-control" placeholder="@(lang == "ar" ? "مثال: محمد أحمد" : "e.g., Mohammad Ahmad")" required />
            </div>

            <div class="mb-3">
                <label class="form-label">@Lang.T("email", lang)</label>
                <input type="email" id="userEmail" class="form-control" placeholder="user@@example.com" required />
            </div>

            <div class="mb-3">
                <label class="form-label">@Lang.T("password", lang)</label>
                <input type="password" id="userPassword" class="form-control" placeholder="@(lang == "ar" ? "8 أحرف على الأقل" : "Min 8 chars, Aa1@@")" required />
                <div class="ui-st-7bfe38" >
                    <i class="bi bi-shield-check me-1"></i>
                    @Lang.T("password_hint", lang)
                </div>
            </div>

            <div class="mb-4">
                <div class="form-check form-switch">
                    <input type="checkbox" id="userIsActive" class="form-check-input" role="switch" checked />
                    <label class="form-check-label ui-st-a5d2ba" >@Lang.T("active", lang)</label>
                </div>
            </div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn-coral" id="userSubmitBtn">
                    <i class="bi bi-check-lg me-1"></i> @Lang.T("create_user", lang)
                </button>
                <button type="button" class="btn-outline-dark" onclick="closeUserModal()">@(lang == "ar" ? "إلغاء" : "Cancel")</button>
            </div>
        </form>
    </div>
</div>
<!-- Edit User Modal -->
<div class="ui-st-fed104" id="editUserModal" onclick="if(event.target===this)closeEditUserModal()">
    <div class="ui-st-0a26e7">
        <div class="ui-st-87d288">
            <h3 class="ui-st-dcc926">@(lang == "ar" ? "تعديل المستخدم" : "Edit User")</h3>
            <button class="ui-st-5a2acb" onclick="closeEditUserModal()">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="ui-st-36b319" id="editUserModalError"></div>
        <form id="editUserForm" data-url="@Url.Action("EditAjax", "Users")">
            <input type="hidden" id="editUserId" />
            <div class="mb-3">
                <label class="form-label">@Lang.T("full_name", lang)</label>
                <input type="text" id="editUserFullName" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">@Lang.T("email", lang)</label>
                <input type="email" id="editUserEmail" class="form-control" required />
            </div>
            <div class="mb-4">
                <div class="form-check form-switch">
                    <input type="checkbox" id="editUserIsActive" class="form-check-input" role="switch" />
                    <label class="form-check-label ui-st-a5d2ba">@Lang.T("active", lang)</label>
                </div>
            </div>
            <div class="d-flex gap-3">
                <button type="submit" class="btn-coral" id="editUserSubmitBtn">
                    <i class="bi bi-check-lg me-1"></i> @(lang == "ar" ? "حفظ التغييرات" : "Save Changes")
                </button>
                <button type="button" class="btn-outline-dark" onclick="closeEditUserModal()">@(lang == "ar" ? "إلغاء" : "Cancel")</button>
            </div>
        </form>
    </div>
</div>

<!-- Email User Modal -->
<div class="ui-st-fed104" id="emailUserModal" onclick="if(event.target===this)closeEmailUserModal()">
    <div class="ui-st-0a26e7">
        <div class="ui-st-87d288">
            <h3 class="ui-st-dcc926">@(lang == "ar" ? "إرسال بريد إلكتروني" : "Send Email")</h3>
            <button class="ui-st-5a2acb" onclick="closeEmailUserModal()">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="ui-st-36b319" id="emailUserModalError"></div>
        <div class="alert alert-success d-none" id="emailUserModalSuccess">@(lang == "ar" ? "تم إرسال البريد الإلكتروني بنجاح!" : "Email sent successfully!")</div>
        <form id="emailUserForm" data-url="@Url.Action("SendEmailAjax", "Users")">
            <input type="hidden" id="emailUserAddress" />
            <div class="mb-3">
                <label class="form-label">@(lang == "ar" ? "إلى" : "To")</label>
                <input type="text" id="emailUserAddressDisplay" class="form-control" disabled />
            </div>
            <div class="mb-3">
                <label class="form-label">@(lang == "ar" ? "العنوان" : "Subject")</label>
                <input type="text" id="emailUserTitle" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">@(lang == "ar" ? "الموضوع" : "Body")</label>
                <textarea id="emailUserSubject" class="form-control" rows="4" required></textarea>
            </div>
            <div class="d-flex gap-3 mt-4">
                <button type="submit" class="btn-coral" id="emailUserSubmitBtn">
                    <i class="bi bi-send me-1"></i> @(lang == "ar" ? "إرسال" : "Send")
                </button>
                <button type="button" class="btn-outline-dark" onclick="closeEmailUserModal()">@(lang == "ar" ? "إلغاء" : "Cancel")</button>
            </div>
        </form>
    </div>
</div>
@section Styles {
    <link rel="stylesheet" href="~/css/pages/users.css" />
}
@section Scripts {
    <script src="~/js/pages/users.js"></script>
}
