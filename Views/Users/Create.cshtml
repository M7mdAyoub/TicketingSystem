@model HelpdeskApp.Models.User
@{
    ViewData["Title"] = "Create User";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="page-header">
            <div>
                <h4 class="page-title">Create User</h4>
                <p class="page-subtitle">Add a new team member to the system</p>
            </div>
        </div>

        <div class="card">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label"><i class="bi bi-person me-1" style="color:var(--primary);"></i> Full Name</label>
                        <input asp-for="FullName" class="form-control" placeholder="e.g., Mohammad Ahmad" />
                        <span asp-validation-for="FullName" class="text-danger" style="font-size:0.8rem;"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"><i class="bi bi-envelope me-1" style="color:var(--primary);"></i> Email</label>
                        <input asp-for="Email" class="form-control" placeholder="user@example.com" />
                        <span asp-validation-for="Email" class="text-danger" style="font-size:0.8rem;"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PasswordHash" class="form-label"><i class="bi bi-lock me-1" style="color:var(--primary);"></i> Password</label>
                        <input asp-for="PasswordHash" class="form-control" type="password" placeholder="Min 8 chars, Aa1@@" />
                        <span asp-validation-for="PasswordHash" class="text-danger" style="font-size:0.8rem;"></span>
                        <div style="margin-top:8px;padding:10px 14px;background:var(--gray-7);border-radius:8px;font-size:0.78rem;color:var(--gray-2);">
                            <i class="bi bi-shield-check me-1" style="color:var(--success);"></i>
                            Requires: 8+ chars, uppercase, lowercase, number, special character
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" role="switch" />
                            <label asp-for="IsActive" class="form-check-label" style="font-weight:600;">Active</label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i> Create User
                        </button>
                        <a href="@Url.Action("Index")" class="btn btn-outline-secondary" style="border-radius:8px;">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
