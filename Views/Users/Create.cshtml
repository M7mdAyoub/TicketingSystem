@model HelpdeskApp.Models.User
@using HelpdeskApp.Data
@{
    ViewData["Title"] = "Create User";
    var lang = Context.Request.Cookies["lang"] ?? "en";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="page-header">
            <div>
                <h4 class="page-title">@Lang.T("create_new_user", lang)</h4>
                <p class="page-subtitle">@(lang == "ar" ? "إضافة عضو جديد للفريق." : "Add a new team member to the system.")</p>
            </div>
        </div>

        <div class="card">
            <div class="card-body ui-st-c0e4fb" >
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label">@Lang.T("full_name", lang)</label>
                        <input asp-for="FullName" class="form-control" placeholder="@(lang == "ar" ? "مثال: محمد أحمد" : "e.g., Mohammad Ahmad")" />
                        <span asp-validation-for="FullName" class="text-danger ui-st-f257e1" ></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">@Lang.T("email", lang)</label>
                        <input asp-for="Email" class="form-control" placeholder="user@@example.com" />
                        <span asp-validation-for="Email" class="text-danger ui-st-f257e1" ></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PasswordHash" class="form-label">@Lang.T("password", lang)</label>
                        <input asp-for="PasswordHash" class="form-control" type="password" placeholder="@(lang == "ar" ? "8 أحرف على الأقل" : "Min 8 chars, Aa1@@")" />
                        <span asp-validation-for="PasswordHash" class="text-danger ui-st-f257e1" ></span>
                        <div class="ui-st-7bfe38" >
                            <i class="bi bi-shield-check me-1"></i>
                            @Lang.T("password_hint", lang)
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" role="switch" />
                            <label asp-for="IsActive" class="form-check-label ui-st-a5d2ba" >@Lang.T("active", lang)</label>
                        </div>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn-coral">
                            <i class="bi bi-check-lg me-1"></i> @Lang.T("create_user", lang)
                        </button>
                        <a href="@Url.Action("Index")" class="btn-outline-dark">@Lang.T("back_to_users", lang)</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
