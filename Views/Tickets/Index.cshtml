@model HelpdeskApp.Models.TicketListViewModel
@{
    ViewData["Title"] = "Tickets";
}

<div class="page-header">
    <div>
        <h4 class="page-title">Tickets</h4>
        <p class="page-subtitle">Track and manage all support requests</p>
    </div>
    <a href="@Url.Action("Create")" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> New Ticket
    </a>
</div>

<!-- Search & Filter -->
<div class="card mb-4">
    <div class="card-body py-3 px-4">
        <form method="get" asp-action="Index">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label" style="font-size:0.82rem;"><i class="bi bi-search me-1"></i>Search</label>
                    <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Search by title..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label" style="font-size:0.82rem;"><i class="bi bi-collection me-1"></i>Category</label>
                    <select name="filterCategoryId" class="form-select">
                        <option value="">All Categories</option>
                        @foreach (var cat in Model.Categories)
                        {
                            <option value="@cat.Id" selected="@(Model.FilterCategoryId == cat.Id)">@cat.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label" style="font-size:0.82rem;"><i class="bi bi-funnel me-1"></i>Status</label>
                    <select name="filterStatus" class="form-select">
                        <option value="">All Statuses</option>
                        <option value="Open" selected="@(Model.FilterStatus == "Open")">Open</option>
                        <option value="InProgress" selected="@(Model.FilterStatus == "InProgress")">In Progress</option>
                        <option value="Closed" selected="@(Model.FilterStatus == "Closed")">Closed</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1">
                        <i class="bi bi-search"></i>
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary" style="border-radius:8px;" title="Clear filters">
                        <i class="bi bi-x-lg"></i>
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Tickets Table -->
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Ticket</th>
                        <th>Category</th>
                        <th>Author</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th style="width:110px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Tickets.Count == 0)
                    {
                        <tr><td colspan="6">
                            <div class="empty-state">
                                <i class="bi bi-inbox"></i>
                                <p>No tickets match your criteria.</p>
                            </div>
                        </td></tr>
                    }
                    @foreach (var ticket in Model.Tickets)
                    {
                        <tr>
                            <td>
                                <a href="@Url.Action("Details", new { id = ticket.Id })" class="text-decoration-none">
                                    <div style="font-weight:700;color:var(--primary);font-size:0.9rem;">@ticket.Title</div>
                                    <div style="font-size:0.78rem;color:var(--gray-3);">#@ticket.Id</div>
                                </a>
                            </td>
                            <td>
                                <span style="padding:4px 10px;border-radius:6px;background:var(--gray-7);font-size:0.82rem;font-weight:600;color:var(--gray-1);">
                                    @ticket.CategoryName
                                </span>
                            </td>
                            <td style="font-size:0.88rem;color:var(--gray-2);">@ticket.CreatedByName</td>
                            <td>
                                @if (ticket.Status == "Open")
                                {
                                    <span class="badge badge-open"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem;"></i>Open</span>
                                }
                                else if (ticket.Status == "InProgress")
                                {
                                    <span class="badge badge-inprogress"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem;"></i>In Progress</span>
                                }
                                else
                                {
                                    <span class="badge badge-closed"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem;"></i>Closed</span>
                                }
                            </td>
                            <td style="font-size:0.85rem;color:var(--gray-2);">@ticket.CreatedDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="@Url.Action("Details", new { id = ticket.Id })" class="btn btn-sm btn-ghost" title="View">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <form asp-action="SoftDelete" asp-route-id="@ticket.Id" method="post" style="display:inline;"
                                          onsubmit="return confirm('Delete this ticket?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-ghost" title="Delete" style="background:rgba(239,68,68,0.08);color:#ef4444;">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Pagination -->
@if (Model.TotalPages > 1)
{
    <nav class="mt-4 d-flex justify-content-center">
        <ul class="pagination">
            @if (Model.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="@Url.Action("Index", new { searchTerm = Model.SearchTerm, filterCategoryId = Model.FilterCategoryId, filterStatus = Model.FilterStatus, page = Model.CurrentPage - 1 })">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
            }

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { searchTerm = Model.SearchTerm, filterCategoryId = Model.FilterCategoryId, filterStatus = Model.FilterStatus, page = i })">@i</a>
                </li>
            }

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" href="@Url.Action("Index", new { searchTerm = Model.SearchTerm, filterCategoryId = Model.FilterCategoryId, filterStatus = Model.FilterStatus, page = Model.CurrentPage + 1 })">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            }
        </ul>
    </nav>
}
