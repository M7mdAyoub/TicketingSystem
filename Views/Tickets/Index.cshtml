@model HelpdeskApp.Models.TicketListViewModel
@using HelpdeskApp.Data
@{
    ViewData["Title"] = "Tickets";
    var lang = Context.Request.Cookies["lang"] ?? "en";
}

<div class="page-header">
    <div>
        <h4 class="page-title">@Lang.T("my_tickets", lang)</h4>
        <p class="page-subtitle">@(lang == "ar" ? "إدارة التدفق الطبيعي لاستفسارات العملاء." : "Oversee the natural flow of client inquiries.")</p>
    </div>
    <a href="@Url.Action("Create")" class="btn-coral">
        <i class="bi bi-plus-lg"></i> @Lang.T("create_new_ticket", lang)
    </a>
</div>

<div class="card mb-4">
    <div class="card-body py-3 px-4">
        <form method="get" asp-action="Index">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label ui-st-6b7c28" ><i class="bi bi-search me-1"></i>@(lang == "ar" ? "بحث" : "Search")</label>
                    <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="@Lang.T("search_tickets", lang)" />
                </div>
                <div class="col-md-3">
                    <label class="form-label ui-st-6b7c28" >@Lang.T("category", lang)</label>
                    <select name="filterCategoryId" class="form-select">
                        <option value="">@Lang.T("all_categories", lang)</option>
                        @foreach (var cat in Model.Categories)
                        {
                            <option value="@cat.Id" selected="@(Model.FilterCategoryId == cat.Id)">@cat.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label ui-st-6b7c28" >@Lang.T("status", lang)</label>
                    <select name="filterStatus" class="form-select">
                        <option value="">@Lang.T("all_statuses", lang)</option>
                        <option value="Open" selected="@(Model.FilterStatus == "Open")">@Lang.T("open", lang)</option>
                        <option value="InProgress" selected="@(Model.FilterStatus == "InProgress")">@Lang.T("in_progress", lang)</option>
                        <option value="Closed" selected="@(Model.FilterStatus == "Closed")">@Lang.T("closed", lang)</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn-coral btn-sm flex-grow-1 ui-st-c157e3" >
                        <i class="bi bi-search"></i>
                    </button>
                    <a href="@Url.Action("Index")" class="btn-outline-dark btn-sm" title="Clear">
                        <i class="bi bi-x-lg"></i>
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

@if (Model.Tickets.Count == 0)
{
    <div class="card">
        <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <p>@Lang.T("no_tickets_found", lang)</p>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var ticket in Model.Tickets)
        {
            <div class="col-md-6 col-lg-4">
                <div class="ticket-card status-@ticket.Status">
                    <div class="d-flex justify-content-between align-items-start ui-st-69a0d1" >
                        @if (ticket.Status == "Open")
                        {
                            <span class="badge-status badge-open">@(lang == "ar" ? "جديدة" : "NEW TICKET")</span>
                        }
                        else if (ticket.Status == "InProgress")
                        {
                            <span class="badge-status badge-inprogress">@(lang == "ar" ? "قيد التنفيذ" : "IN PROGRESS")</span>
                        }
                        else
                        {
                            <span class="badge-status badge-resolved">@(lang == "ar" ? "محلولة" : "RESOLVED")</span>
                        }
                        <span class="ui-st-33eb74" >#TK-@ticket.Id</span>
                    </div>
                    <a href="@Url.Action("Details", new { id = ticket.Id })" class="text-decoration-none ui-st-69a0d1" >
                        <div class="ticket-card-title">@(ticket.Title.Length > 35 ? ticket.Title.Substring(0, 35) + "..." : ticket.Title)</div>
                    </a>
                    <div class="ticket-card-desc ui-st-69a0d1" >@(ticket.Description.Length > 90 ? ticket.Description.Substring(0, 90) + "..." : ticket.Description)</div>
                    <div class="ticket-card-footer ui-st-ae304b" >
                        <div class="d-flex align-items-center gap-2">
                            <div class="ui-st-e535dd" >
                                @{
                                    var tParts = ticket.CreatedByName?.Split(' ') ?? new[] { "U" };
                                    var tInit = tParts.Length >= 2
                                        ? tParts[0].Substring(0,1).ToUpper() + tParts[^1].Substring(0,1).ToUpper()
                                        : (ticket.CreatedByName ?? "U").Substring(0,1).ToUpper();
                                }
                                @tInit
                            </div>
                            <span class="ui-st-5384c2" >@(ticket.CreatedByName?.Split(' ')[0]) @(ticket.CreatedByName?.Split(' ').Length > 1 ? ticket.CreatedByName.Split(' ')[^1].Substring(0,1) + "." : "")</span>
                        </div>
                        <span class="ui-st-45df8c" >@ticket.CreatedDate.ToString("MMM dd")</span>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (Model.TotalPages > 1)
{
    <div class="d-flex justify-content-between align-items-center mt-4">
        <span class="ui-st-1e8514" >@Lang.T("page", lang) @Model.CurrentPage @Lang.T("of", lang) @Model.TotalPages</span>
        <nav>
            <ul class="pagination">
                @if (Model.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", new { searchTerm = Model.SearchTerm, filterCategoryId = Model.FilterCategoryId, filterStatus = Model.FilterStatus, page = Model.CurrentPage - 1 })">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                }
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { searchTerm = Model.SearchTerm, filterCategoryId = Model.FilterCategoryId, filterStatus = Model.FilterStatus, page = i })">@i</a>
                    </li>
                }
                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", new { searchTerm = Model.SearchTerm, filterCategoryId = Model.FilterCategoryId, filterStatus = Model.FilterStatus, page = Model.CurrentPage + 1 })">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                }
            </ul>
        </nav>
    </div>
}
