@model HelpdeskApp.Models.TicketListViewModel
@{
    ViewData["Title"] = "Tickets";
}

<div class="page-header">
    <div>
        <h4 class="page-title">All Support Tickets</h4>
        <p class="page-subtitle">Oversee the natural flow of client inquiries.</p>
    </div>
    <a href="@Url.Action("Create")" class="btn-coral">
        <i class="bi bi-plus-lg"></i> New Ticket
    </a>
</div>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-body py-3 px-4">
        <form method="get" asp-action="Index">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label" style="font-size:0.82rem;"><i class="bi bi-search me-1"></i>Search</label>
                    <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Search across all tickets..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label" style="font-size:0.82rem;">Category</label>
                    <select name="filterCategoryId" class="form-select">
                        <option value="">All Categories</option>
                        @foreach (var cat in Model.Categories)
                        {
                            <option value="@cat.Id" selected="@(Model.FilterCategoryId == cat.Id)">@cat.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label" style="font-size:0.82rem;">Status</label>
                    <select name="filterStatus" class="form-select">
                        <option value="">All Statuses</option>
                        <option value="Open" selected="@(Model.FilterStatus == "Open")">Open</option>
                        <option value="InProgress" selected="@(Model.FilterStatus == "InProgress")">In Progress</option>
                        <option value="Closed" selected="@(Model.FilterStatus == "Closed")">Closed</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn-coral btn-sm flex-grow-1" style="justify-content:center;">
                        <i class="bi bi-search"></i>
                    </button>
                    <a href="@Url.Action("Index")" class="btn-outline-dark btn-sm" title="Clear">
                        <i class="bi bi-x-lg"></i>
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Ticket Cards Grid -->
@if (Model.Tickets.Count == 0)
{
    <div class="card">
        <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <p>No tickets match your criteria.</p>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var ticket in Model.Tickets)
        {
            <div class="col-md-6 col-lg-4">
                <div class="ticket-card status-@ticket.Status">
                    <div class="d-flex justify-content-between align-items-start" style="padding-left:12px;">
                        @if (ticket.Status == "Open")
                        {
                            <span class="badge-status badge-open">NEW TICKET</span>
                        }
                        else if (ticket.Status == "InProgress")
                        {
                            <span class="badge-status badge-inprogress">IN PROGRESS</span>
                        }
                        else
                        {
                            <span class="badge-status badge-resolved">RESOLVED</span>
                        }
                        <span style="font-size:0.78rem;color:var(--text-light);font-weight:600;">#TK-@ticket.Id</span>
                    </div>
                    <a href="@Url.Action("Details", new { id = ticket.Id })" class="text-decoration-none" style="padding-left:12px;">
                        <div class="ticket-card-title">@(ticket.Title.Length > 35 ? ticket.Title.Substring(0, 35) + "..." : ticket.Title)</div>
                    </a>
                    <div class="ticket-card-desc" style="padding-left:12px;">@(ticket.Description.Length > 90 ? ticket.Description.Substring(0, 90) + "..." : ticket.Description)</div>
                    <div class="ticket-card-footer" style="margin-left:12px;">
                        <div class="d-flex align-items-center gap-2">
                            <div style="width:26px;height:26px;border-radius:50%;background:var(--green-dark);color:#fff;display:flex;align-items:center;justify-content:center;font-size:0.6rem;font-weight:700;">
                                @{
                                    var tParts = ticket.CreatedByName?.Split(' ') ?? new[] { "U" };
                                    var tInit = tParts.Length >= 2
                                        ? tParts[0].Substring(0,1).ToUpper() + tParts[^1].Substring(0,1).ToUpper()
                                        : (ticket.CreatedByName ?? "U").Substring(0,1).ToUpper();
                                }
                                @tInit
                            </div>
                            <span style="font-weight:600;font-size:0.8rem;color:var(--dark);">@(ticket.CreatedByName?.Split(' ')[0]) @(ticket.CreatedByName?.Split(' ').Length > 1 ? ticket.CreatedByName.Split(' ')[^1].Substring(0,1) + "." : "")</span>
                        </div>
                        <span style="font-size:0.78rem;font-weight:600;color:var(--text-light);text-transform:uppercase;">@ticket.CreatedDate.ToString("MMM dd")</span>
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Pagination -->
@if (Model.TotalPages > 1)
{
    <div class="d-flex justify-content-between align-items-center mt-4">
        <span style="font-size:0.85rem;color:var(--text-muted);">Showing @((Model.CurrentPage - 1) * 5 + 1) to @Math.Min(Model.CurrentPage * 5, Model.TotalPages * 5) of @(Model.TotalPages * 5) tickets</span>
        <nav>
            <ul class="pagination">
                @if (Model.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", new { searchTerm = Model.SearchTerm, filterCategoryId = Model.FilterCategoryId, filterStatus = Model.FilterStatus, page = Model.CurrentPage - 1 })">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                }
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { searchTerm = Model.SearchTerm, filterCategoryId = Model.FilterCategoryId, filterStatus = Model.FilterStatus, page = i })">@i</a>
                    </li>
                }
                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", new { searchTerm = Model.SearchTerm, filterCategoryId = Model.FilterCategoryId, filterStatus = Model.FilterStatus, page = Model.CurrentPage + 1 })">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                }
            </ul>
        </nav>
    </div>
}
