@model HelpdeskApp.Models.Ticket
@{
    ViewData["Title"] = "Create Ticket";
    var categories = ViewBag.Categories as List<HelpdeskApp.Models.Category>;
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <div class="page-header">
            <div>
                <h4 class="page-title">Create New Ticket</h4>
                <p class="page-subtitle">Submit a support request to the team.</p>
            </div>
        </div>

        <div class="card">
            <div class="card-body" style="padding:32px;">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Title</label>
                        <input asp-for="Title" class="form-control" placeholder="Brief summary of the issue" />
                        <span asp-validation-for="Title" class="text-danger" style="font-size:0.8rem;"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="5" placeholder="Describe the issue in detail..." style="resize:vertical;"></textarea>
                        <span asp-validation-for="Description" class="text-danger" style="font-size:0.8rem;"></span>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="CategoryId" class="form-label">Category</label>
                            <select asp-for="CategoryId" class="form-select">
                                <option value="">Select a category</option>
                                @if (categories != null)
                                {
                                    @foreach (var cat in categories)
                                    {
                                        <option value="@cat.Id">@cat.Name</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger" style="font-size:0.8rem;"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label">Status</label>
                            <select asp-for="Status" class="form-select">
                                <option value="Open">Open</option>
                                <option value="InProgress">In Progress</option>
                                <option value="Closed">Closed</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn-coral">
                            <i class="bi bi-send me-1"></i> Submit Ticket
                        </button>
                        <a href="@Url.Action("Index")" class="btn-outline-dark">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
