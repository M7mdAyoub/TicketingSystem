@model HelpdeskApp.Models.Ticket
@using HelpdeskApp.Data
@{
    ViewData["Title"] = "Create Ticket";
    var categories = ViewBag.Categories as List<HelpdeskApp.Models.Category>;
    var lang = Context.Request.Cookies["lang"] ?? "en";
}

<div class="ui-st-e99b56" >
    <a class="ui-st-761126" href="@Url.Action("Index")" >@Lang.T("tickets", lang)</a>
    <span class="ui-st-bbaacd" >›</span>
    <span class="ui-st-d5315c" >@Lang.T("create_new_ticket", lang)</span>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card ui-st-b5d011" >
            <div class="text-center mb-4">
                <h2 class="ui-st-3f1afd" >@Lang.T("create_new_ticket", lang)</h2>
                <p class="ui-st-c26419" >@(lang == "ar" ? "قدّم طلبك وسيقوم فريق الدعم بمساعدتك قريباً." : "Submit your request and our nature-inspired support team will assist you shortly.")</p>
            </div>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-4">
                    <label asp-for="Title" class="form-label ui-st-116c07" >@Lang.T("title", lang)</label>
                    <input asp-for="Title" class="form-control ui-st-398f57" placeholder="@Lang.T("ticket_title_ph", lang)"  />
                    <span asp-validation-for="Title" class="text-danger ui-st-f257e1" ></span>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="CategoryId" class="form-label ui-st-116c07" >@Lang.T("category", lang)</label>
                        <select asp-for="CategoryId" class="form-select ui-st-398f57" >
                            <option value="">@Lang.T("select_category", lang)</option>
                            @if (categories != null)
                            {
                                @foreach (var cat in categories)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger ui-st-f257e1" ></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Status" class="form-label ui-st-116c07" >@Lang.T("status", lang)</label>
                        <select asp-for="Status" class="form-select ui-st-398f57" >
                            <option value="Open">@Lang.T("open", lang)</option>
                            <option value="InProgress">@Lang.T("in_progress", lang)</option>
                            <option value="Closed">@Lang.T("closed", lang)</option>
                        </select>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label ui-st-116c07" >@Lang.T("description", lang)</label>
                    <textarea asp-for="Description" class="form-control ui-st-56f8c7" rows="6" placeholder="@Lang.T("ticket_desc_ph", lang)" ></textarea>
                    <span asp-validation-for="Description" class="text-danger ui-st-f257e1" ></span>
                </div>

                <hr class="ui-st-9456dc"  />

                <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                    <a class="ui-st-2ef33c" href="@Url.Action("Index")" >@Lang.T("back_to_tickets", lang)</a>
                    <div class="d-flex gap-3">
                        <button type="submit" class="btn-coral ui-st-1c07ff" >
                            <i class="bi bi-send-fill me-1"></i> @Lang.T("submit", lang)
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <div class="row g-4 mt-4">
            <div class="col-md-4">
                <div class="d-flex align-items-start gap-3">
                    <div class="ui-st-797857" >
                        <i class="bi bi-stars"></i>
                    </div>
                    <div>
                        <div class="ui-st-af04c1" >@(lang == "ar" ? "توجيه ذكي" : "Smart Routing")</div>
                        <div class="ui-st-b91605" >@(lang == "ar" ? "يتم تعيين تذكرتك تلقائياً لأفضل خبير متاح." : "Your ticket is automatically assigned to the best available expert.")</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="d-flex align-items-start gap-3">
                    <div class="ui-st-797857" >
                        <i class="bi bi-clock-history"></i>
                    </div>
                    <div>
                        <div class="ui-st-af04c1" >@(lang == "ar" ? "استجابة خلال 24 ساعة" : "24h Response")</div>
                        <div class="ui-st-b91605" >@(lang == "ar" ? "نهدف للرد على جميع الاستفسارات خلال يوم عمل واحد." : "We aim to respond to all standard inquiries within one business day.")</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="d-flex align-items-start gap-3">
                    <div class="ui-st-797857" >
                        <i class="bi bi-shield-lock"></i>
                    </div>
                    <div>
                        <div class="ui-st-af04c1" >@(lang == "ar" ? "معالجة آمنة" : "Secure Handling")</div>
                        <div class="ui-st-b91605" >@(lang == "ar" ? "جميع البيانات المشاركة مشفرة وسرية تماماً." : "All data shared in this form is encrypted and strictly confidential.")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
