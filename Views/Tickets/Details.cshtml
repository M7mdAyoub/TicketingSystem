@model HelpdeskApp.Models.Ticket
@using HelpdeskApp.Data
@{
    ViewData["Title"] = "Ticket #" + Model.Id;
    var currentUserId = int.Parse(Context.User?.FindFirst("UserId")?.Value ?? "0");
    var lang = Context.Request.Cookies["lang"] ?? "en";
}

<div class="ui-st-e99b56" >
    <a class="ui-st-278047" href="@Url.Action("Index")" >@Lang.T("tickets", lang)</a>
    <span class="ui-st-bbaacd" >›</span>
    <span class="ui-st-74de57" >@Model.CategoryName</span>
    <span class="ui-st-bbaacd" >›</span>
    <strong class="ui-st-c053b6" >INC-@Model.Id</strong>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="d-flex align-items-start justify-content-between mb-3">
            <h2 class="ui-st-5bf720" >@Model.Title</h2>
        </div>

        <div class="d-flex align-items-center gap-3 mb-4">
            <div class="ui-st-206e94" >
                @{
                    var dParts = Model.CreatedByName?.Split(' ') ?? new[] { "U" };
                    var dInit = dParts.Length >= 2
                        ? dParts[0].Substring(0,1).ToUpper() + dParts[^1].Substring(0,1).ToUpper()
                        : (Model.CreatedByName ?? "U").Substring(0,1).ToUpper();
                }
                @dInit
            </div>
            <div>
                <span class="ui-st-1e8514" >@Lang.T("reported_by", lang) </span>
                <strong class="ui-st-6206b4" >@Model.CreatedByName</strong>
                <span class="ui-st-545d10" > • @Model.CreatedDate.ToString("MMM dd, yyyy")</span>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-body">
                <h5 class="ui-st-471d13" >@Lang.T("description", lang)</h5>
                <p class="ui-st-282f7a" >@Model.Description</p>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <i class="bi bi-chat-dots-fill ui-st-bc7c44" ></i>
                <span>@Lang.T("comments", lang)</span>
            </div>
            <div class="card-body">
                @if (Model.Comments != null && Model.Comments.Count > 0)
                {
                    @foreach (var comment in Model.Comments)
                    {
                        var isCurrentUser = comment.CreatedByU == currentUserId;
                        <div class="d-flex gap-3 mb-3 flex-dir-@(isCurrentUser ? "reverse" : "normal")">
                            @if (!isCurrentUser)
                            {
                                <div class="ui-st-dad2fe" >
                                    @{
                                        var cParts = comment.CreatedByName?.Split(' ') ?? new[] { "U" };
                                        var cInit = cParts.Length >= 2
                                            ? cParts[0].Substring(0,1).ToUpper() + cParts[^1].Substring(0,1).ToUpper()
                                            : (comment.CreatedByName ?? "U").Substring(0,1).ToUpper();
                                    }
                                    @cInit
                                </div>
                            }
                            <div class="comment-bubble @(isCurrentUser ? "right" : "left")">
                                <div class="comment-author ui-st-25aea1" >@comment.CreatedByName</div>
                                <p class="ui-st-da0d7d" >@comment.CommentText</p>
                                <div class="comment-date">@comment.CreatedDate.ToString("MMM dd, yyyy hh:mm tt")</div>
                            </div>
                            @if (isCurrentUser)
                            {
                                <div class="ui-st-1fdb36" >
                                    @{
                                        var mParts = comment.CreatedByName?.Split(' ') ?? new[] { "U" };
                                        var mInit = mParts.Length >= 2
                                            ? mParts[0].Substring(0,1).ToUpper() + mParts[^1].Substring(0,1).ToUpper()
                                            : (comment.CreatedByName ?? "U").Substring(0,1).ToUpper();
                                    }
                                    @mInit
                                </div>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state ui-st-c0e4fb" >
                        <i class="bi bi-chat ui-st-cf44b5" ></i>
                        <p>@Lang.T("no_comments", lang)</p>
                    </div>
                }

                @if (Model.Status != "Closed")
                {
                    <div class="ui-st-40f66d" >
                        <form asp-action="AddComment" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ticketId" value="@Model.Id" />
                            <textarea name="commentText" class="form-control ui-st-82922d" rows="3" placeholder="@Lang.T("write_comment", lang)" required ></textarea>
                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn-coral btn-sm">
                                    <i class="bi bi-send me-1"></i> @Lang.T("post_comment", lang)
                                </button>
                            </div>
                        </form>
                    </div>
                }
                else
                {
                    <div class="ui-st-df93df" >
                        <i class="bi bi-lock-fill me-1"></i> @Lang.T("ticket_closed_msg", lang)
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-sliders ui-st-91d6b3" ></i>
                @(lang == "ar" ? "التحكم بالتذكرة" : "Ticket Controls")
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="ui-st-ee964e" >@Lang.T("status", lang)</div>
                    <form asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <div class="d-flex gap-2">
                            <select name="status" class="form-select form-select-sm">
                                <option value="Open" selected="@(Model.Status == "Open")">🟢 @Lang.T("open", lang)</option>
                                <option value="InProgress" selected="@(Model.Status == "InProgress")">🟡 @Lang.T("in_progress", lang)</option>
                                <option value="Closed" selected="@(Model.Status == "Closed")">⚫ @Lang.T("closed", lang)</option>
                            </select>
                            <button type="submit" class="btn-coral btn-sm ui-st-8b2da0" >@Lang.T("update_status", lang)</button>
                        </div>
                    </form>
                </div>

                <div class="mb-3">
                    <div class="ui-st-ee964e" >@Lang.T("category", lang)</div>
                    <div class="ui-st-d14ba8" >
                        <i class="bi bi-tag-fill ui-st-91d6b3" ></i> @Model.CategoryName
                    </div>
                </div>

                <hr class="ui-st-b52610"  />

                <form asp-action="SoftDelete" asp-route-id="@Model.Id" method="post" id="deleteForm" data-confirm="@Lang.T("delete_confirm", lang)">

                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-ghost ui-st-ae7fde" >
                        <i class="bi bi-trash3 me-1"></i> @Lang.T("delete_ticket", lang)
                    </button>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <i class="bi bi-info-circle-fill ui-st-bc7c44" ></i>
                @Lang.T("ticket_details", lang)
            </div>
            <div class="card-body ui-st-7df75a" >
                <div class="d-flex justify-content-between mb-3 pb-3 ui-st-4fc1ed" >
                    <span class="ui-st-697a24" >@(lang == "ar" ? "رقم التذكرة" : "Ticket ID")</span>
                    <strong class="ui-st-c053b6" >#INC-@Model.Id</strong>
                </div>
                <div class="d-flex justify-content-between mb-3 pb-3 ui-st-4fc1ed" >
                    <span class="ui-st-697a24" >@Lang.T("status", lang)</span>
                    @if (Model.Status == "Open") { <span class="badge-status badge-open">@Lang.T("open", lang)</span> }
                    else if (Model.Status == "InProgress") { <span class="badge-status badge-inprogress">@Lang.T("in_progress", lang)</span> }
                    else { <span class="badge-status badge-resolved">@Lang.T("closed", lang)</span> }
                </div>
                <div class="d-flex justify-content-between mb-3 pb-3 ui-st-4fc1ed" >
                    <span class="ui-st-697a24" >@Lang.T("category", lang)</span>
                    <strong class="ui-st-c053b6" >@Model.CategoryName</strong>
                </div>
                <div class="d-flex justify-content-between mb-3 pb-3 ui-st-4fc1ed" >
                    <span class="ui-st-697a24" >@Lang.T("created_by", lang)</span>
                    <strong class="ui-st-c053b6" >@Model.CreatedByName</strong>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="ui-st-697a24" >@Lang.T("created_date", lang)</span>
                    <strong class="ui-st-c053b6" >@Model.CreatedDate.ToString("MMM dd, yyyy")</strong>
                </div>
            </div>
        </div>
    </div>
</div>
