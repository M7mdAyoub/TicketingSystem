@model HelpdeskApp.Models.Ticket
@using HelpdeskApp.Data
@{
    ViewData["Title"] = "Ticket #" + Model.Id;
    var currentUserId = int.Parse(Context.User?.FindFirst("UserId")?.Value ?? "0");
    var lang = Context.Request.Cookies["lang"] ?? "en";
}

<div style="font-size:0.85rem;color:var(--text-muted);margin-bottom:24px;">
    <a href="@Url.Action("Index")" style="color:var(--coral);text-decoration:none;font-weight:600;">@Lang.T("tickets", lang)</a>
    <span style="margin:0 8px;">›</span>
    <span style="color:var(--text-light);">@Model.CategoryName</span>
    <span style="margin:0 8px;">›</span>
    <strong style="color:var(--dark);">INC-@Model.Id</strong>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="d-flex align-items-start justify-content-between mb-3">
            <h2 style="font-family:var(--font-serif);font-weight:800;font-size:1.6rem;color:var(--dark);line-height:1.3;max-width:80%;">@Model.Title</h2>
        </div>

        <div class="d-flex align-items-center gap-3 mb-4">
            <div style="width:36px;height:36px;border-radius:50%;background:var(--green-dark);color:#fff;display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:700;">
                @{
                    var dParts = Model.CreatedByName?.Split(' ') ?? new[] { "U" };
                    var dInit = dParts.Length >= 2
                        ? dParts[0].Substring(0,1).ToUpper() + dParts[^1].Substring(0,1).ToUpper()
                        : (Model.CreatedByName ?? "U").Substring(0,1).ToUpper();
                }
                @dInit
            </div>
            <div>
                <span style="font-size:0.85rem;color:var(--text-muted);">@Lang.T("reported_by", lang) </span>
                <strong style="color:var(--dark);font-size:0.88rem;">@Model.CreatedByName</strong>
                <span style="font-size:0.85rem;color:var(--text-light);"> • @Model.CreatedDate.ToString("MMM dd, yyyy")</span>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-body">
                <h5 style="font-family:var(--font-serif);font-weight:700;margin-bottom:14px;font-size:1rem;">@Lang.T("description", lang)</h5>
                <p style="white-space:pre-line;color:var(--text);line-height:1.8;font-size:0.92rem;margin:0;">@Model.Description</p>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <i class="bi bi-chat-dots-fill" style="color:var(--coral);"></i>
                <span>@Lang.T("comments", lang)</span>
            </div>
            <div class="card-body">
                @if (Model.Comments != null && Model.Comments.Count > 0)
                {
                    @foreach (var comment in Model.Comments)
                    {
                        var isCurrentUser = comment.CreatedByU == currentUserId;
                        <div class="d-flex gap-3 mb-3" style="flex-direction:@(isCurrentUser ? "row-reverse" : "row");">
                            @if (!isCurrentUser)
                            {
                                <div style="width:36px;height:36px;border-radius:50%;background:var(--green-dark);color:#fff;display:flex;align-items:center;justify-content:center;font-size:0.65rem;font-weight:700;flex-shrink:0;">
                                    @{
                                        var cParts = comment.CreatedByName?.Split(' ') ?? new[] { "U" };
                                        var cInit = cParts.Length >= 2
                                            ? cParts[0].Substring(0,1).ToUpper() + cParts[^1].Substring(0,1).ToUpper()
                                            : (comment.CreatedByName ?? "U").Substring(0,1).ToUpper();
                                    }
                                    @cInit
                                </div>
                            }
                            <div class="comment-bubble @(isCurrentUser ? "right" : "left")">
                                <div class="comment-author" style="margin-bottom:6px;">@comment.CreatedByName</div>
                                <p style="margin:0;font-size:0.88rem;line-height:1.6;">@comment.CommentText</p>
                                <div class="comment-date">@comment.CreatedDate.ToString("MMM dd, yyyy hh:mm tt")</div>
                            </div>
                            @if (isCurrentUser)
                            {
                                <div style="width:36px;height:36px;border-radius:50%;background:var(--coral);color:#fff;display:flex;align-items:center;justify-content:center;font-size:0.65rem;font-weight:700;flex-shrink:0;">
                                    @{
                                        var mParts = comment.CreatedByName?.Split(' ') ?? new[] { "U" };
                                        var mInit = mParts.Length >= 2
                                            ? mParts[0].Substring(0,1).ToUpper() + mParts[^1].Substring(0,1).ToUpper()
                                            : (comment.CreatedByName ?? "U").Substring(0,1).ToUpper();
                                    }
                                    @mInit
                                </div>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state" style="padding:32px;">
                        <i class="bi bi-chat" style="font-size:2.5rem;"></i>
                        <p>@Lang.T("no_comments", lang)</p>
                    </div>
                }

                @if (Model.Status != "Closed")
                {
                    <div style="margin-top:20px;padding-top:20px;border-top:1px dashed var(--border);">
                        <form asp-action="AddComment" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ticketId" value="@Model.Id" />
                            <textarea name="commentText" class="form-control" rows="3" placeholder="@Lang.T("write_comment", lang)" required style="resize:vertical;margin-bottom:12px;"></textarea>
                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn-coral btn-sm">
                                    <i class="bi bi-send me-1"></i> @Lang.T("post_comment", lang)
                                </button>
                            </div>
                        </form>
                    </div>
                }
                else
                {
                    <div style="margin-top:16px;padding:14px 20px;background:#fefce8;border:1px solid #fde68a;border-radius:var(--radius);color:#92400e;font-size:0.88rem;">
                        <i class="bi bi-lock-fill me-1"></i> @Lang.T("ticket_closed_msg", lang)
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-sliders" style="color:var(--green-mid);"></i>
                @(lang == "ar" ? "التحكم بالتذكرة" : "Ticket Controls")
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--coral);font-weight:700;margin-bottom:6px;">@Lang.T("status", lang)</div>
                    <form asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <div class="d-flex gap-2">
                            <select name="status" class="form-select form-select-sm">
                                <option value="Open" selected="@(Model.Status == "Open")">🟢 @Lang.T("open", lang)</option>
                                <option value="InProgress" selected="@(Model.Status == "InProgress")">🟡 @Lang.T("in_progress", lang)</option>
                                <option value="Closed" selected="@(Model.Status == "Closed")">⚫ @Lang.T("closed", lang)</option>
                            </select>
                            <button type="submit" class="btn-coral btn-sm" style="white-space:nowrap;">@Lang.T("update_status", lang)</button>
                        </div>
                    </form>
                </div>

                <div class="mb-3">
                    <div style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--coral);font-weight:700;margin-bottom:6px;">@Lang.T("category", lang)</div>
                    <div style="padding:8px 14px;background:var(--cream);border-radius:8px;font-weight:600;font-size:0.88rem;display:flex;align-items:center;gap:8px;">
                        <i class="bi bi-tag-fill" style="color:var(--green-mid);"></i> @Model.CategoryName
                    </div>
                </div>

                <hr style="border-color:var(--border-light);" />

                <form asp-action="SoftDelete" asp-route-id="@Model.Id" method="post" id="deleteForm"
                      onsubmit="return confirm('@Lang.T("delete_confirm", lang)');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-ghost" style="width:100%;text-align:center;color:var(--text-muted);font-weight:600;">
                        <i class="bi bi-trash3 me-1"></i> @Lang.T("delete_ticket", lang)
                    </button>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <i class="bi bi-info-circle-fill" style="color:var(--coral);"></i>
                @Lang.T("ticket_details", lang)
            </div>
            <div class="card-body" style="font-size:0.88rem;">
                <div class="d-flex justify-content-between mb-3 pb-3" style="border-bottom:1px solid var(--border-light);">
                    <span style="color:var(--text-muted);">@(lang == "ar" ? "رقم التذكرة" : "Ticket ID")</span>
                    <strong style="color:var(--dark);">#INC-@Model.Id</strong>
                </div>
                <div class="d-flex justify-content-between mb-3 pb-3" style="border-bottom:1px solid var(--border-light);">
                    <span style="color:var(--text-muted);">@Lang.T("status", lang)</span>
                    @if (Model.Status == "Open") { <span class="badge-status badge-open">@Lang.T("open", lang)</span> }
                    else if (Model.Status == "InProgress") { <span class="badge-status badge-inprogress">@Lang.T("in_progress", lang)</span> }
                    else { <span class="badge-status badge-resolved">@Lang.T("closed", lang)</span> }
                </div>
                <div class="d-flex justify-content-between mb-3 pb-3" style="border-bottom:1px solid var(--border-light);">
                    <span style="color:var(--text-muted);">@Lang.T("category", lang)</span>
                    <strong style="color:var(--dark);">@Model.CategoryName</strong>
                </div>
                <div class="d-flex justify-content-between mb-3 pb-3" style="border-bottom:1px solid var(--border-light);">
                    <span style="color:var(--text-muted);">@Lang.T("created_by", lang)</span>
                    <strong style="color:var(--dark);">@Model.CreatedByName</strong>
                </div>
                <div class="d-flex justify-content-between">
                    <span style="color:var(--text-muted);">@Lang.T("created_date", lang)</span>
                    <strong style="color:var(--dark);">@Model.CreatedDate.ToString("MMM dd, yyyy")</strong>
                </div>
            </div>
        </div>
    </div>
</div>
