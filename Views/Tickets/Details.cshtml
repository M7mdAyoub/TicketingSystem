@model HelpdeskApp.Models.Ticket
@{
    ViewData["Title"] = "Ticket #" + Model.Id;
}

<div class="mb-4">
    <a href="@Url.Action("Index")" class="btn btn-ghost btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Back to Tickets
    </a>
</div>

<div class="row g-4">
    <!-- Main Content -->
    <div class="col-lg-8">
        <!-- Ticket Card -->
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-3">
                    <div style="width:40px;height:40px;border-radius:10px;background:linear-gradient(135deg,#6366f1,#8b5cf6);display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-ticket-detailed" style="color:#fff;font-size:1rem;"></i>
                    </div>
                    <div>
                        <h5 style="margin:0;font-weight:800;font-size:1.1rem;color:var(--dark);">@Model.Title</h5>
                        <span style="font-size:0.78rem;color:var(--gray-3);">Ticket #@Model.Id</span>
                    </div>
                </div>
                @if (Model.Status == "Open")
                {
                    <span class="badge badge-open" style="font-size:0.82rem;padding:6px 16px;"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem;"></i>Open</span>
                }
                else if (Model.Status == "InProgress")
                {
                    <span class="badge badge-inprogress" style="font-size:0.82rem;padding:6px 16px;"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem;"></i>In Progress</span>
                }
                else
                {
                    <span class="badge badge-closed" style="font-size:0.82rem;padding:6px 16px;"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem;"></i>Closed</span>
                }
            </div>
            <div class="card-body">
                <div style="white-space:pre-line;color:var(--gray-1);line-height:1.8;font-size:0.92rem;margin-bottom:24px;">@Model.Description</div>

                <div class="row g-3">
                    <div class="col-md-4">
                        <div style="padding:14px 16px;background:var(--gray-7);border-radius:10px;">
                            <div style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--gray-3);font-weight:700;margin-bottom:4px;">Category</div>
                            <div style="font-weight:700;color:var(--dark);font-size:0.9rem;"><i class="bi bi-tag me-1" style="color:var(--primary);"></i>@Model.CategoryName</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div style="padding:14px 16px;background:var(--gray-7);border-radius:10px;">
                            <div style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--gray-3);font-weight:700;margin-bottom:4px;">Created By</div>
                            <div style="font-weight:700;color:var(--dark);font-size:0.9rem;"><i class="bi bi-person me-1" style="color:var(--secondary);"></i>@Model.CreatedByName</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div style="padding:14px 16px;background:var(--gray-7);border-radius:10px;">
                            <div style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--gray-3);font-weight:700;margin-bottom:4px;">Created</div>
                            <div style="font-weight:700;color:var(--dark);font-size:0.9rem;"><i class="bi bi-calendar3 me-1" style="color:var(--accent);"></i>@Model.CreatedDate.ToString("MMM dd, yyyy")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Comments -->
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-chat-dots-fill" style="color:var(--primary);"></i>
                <span>Comments</span>
                <span class="badge" style="background:var(--primary-glow);color:var(--primary);font-weight:700;margin-left:4px;">@(Model.Comments?.Count ?? 0)</span>
            </div>
            <div class="card-body">
                @if (Model.Comments != null && Model.Comments.Count > 0)
                {
                    @foreach (var comment in Model.Comments)
                    {
                        <div class="comment-item">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width:30px;height:30px;border-radius:8px;background:linear-gradient(135deg,#6366f1,#06b6d4);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:0.7rem;">
                                        @{
                                            var cParts = comment.CreatedByName?.Split(' ') ?? new[] { "U" };
                                            var cInit = cParts.Length >= 2
                                                ? cParts[0].Substring(0,1).ToUpper() + cParts[^1].Substring(0,1).ToUpper()
                                                : (comment.CreatedByName ?? "U").Substring(0,1).ToUpper();
                                        }
                                        @cInit
                                    </div>
                                    <span class="comment-author">@comment.CreatedByName</span>
                                </div>
                                <span class="comment-date">@comment.CreatedDate.ToString("MMM dd, yyyy hh:mm tt")</span>
                            </div>
                            <p style="margin:0;color:var(--gray-1);font-size:0.9rem;line-height:1.6;padding-left:42px;">@comment.CommentText</p>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state" style="padding:32px;">
                        <i class="bi bi-chat" style="font-size:2.5rem;"></i>
                        <p>No comments yet. Be the first to respond.</p>
                    </div>
                }

                @if (Model.Status != "Closed")
                {
                    <div style="margin-top:20px;padding-top:20px;border-top:1px solid var(--gray-5);">
                        <form asp-action="AddComment" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ticketId" value="@Model.Id" />
                            <div class="mb-3">
                                <label class="form-label" style="font-size:0.88rem;"><i class="bi bi-pencil me-1" style="color:var(--primary);"></i> Add Comment</label>
                                <textarea name="commentText" class="form-control" rows="3" placeholder="Write your response..." required style="resize:vertical;"></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary btn-sm">
                                <i class="bi bi-send me-1"></i> Post Comment
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="alert" style="background:linear-gradient(135deg,#fefce8,#fef9c3);color:#854d0e;margin-top:16px;margin-bottom:0;">
                        <i class="bi bi-lock-fill"></i> This ticket is closed — comments are disabled.
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">
        <!-- Actions -->
        <div class="card mb-4">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-lightning-fill" style="color:var(--warning);"></i> Quick Actions
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label" style="font-size:0.82rem;">Update Status</label>
                    <form asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <div class="d-flex gap-2">
                            <select name="status" class="form-select form-select-sm">
                                <option value="Open" selected="@(Model.Status == "Open")">Open</option>
                                <option value="InProgress" selected="@(Model.Status == "InProgress")">In Progress</option>
                                <option value="Closed" selected="@(Model.Status == "Closed")">Closed</option>
                            </select>
                            <button type="submit" class="btn btn-sm btn-primary" style="white-space:nowrap;">Update</button>
                        </div>
                    </form>
                </div>

                <hr style="border-color:var(--gray-5);" />

                <form asp-action="SoftDelete" asp-route-id="@Model.Id" method="post"
                      onsubmit="return confirm('Are you sure you want to delete this ticket?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm w-100" style="background:rgba(239,68,68,0.08);color:#ef4444;font-weight:600;border-radius:8px;">
                        <i class="bi bi-trash3 me-1"></i> Delete Ticket
                    </button>
                </form>
            </div>
        </div>

        <!-- Info -->
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-info-circle-fill" style="color:var(--secondary);"></i> Details
            </div>
            <div class="card-body" style="font-size:0.88rem;">
                <div class="d-flex justify-content-between mb-3 pb-3" style="border-bottom:1px solid var(--gray-6);">
                    <span style="color:var(--gray-2);">Ticket ID</span>
                    <span style="font-weight:700;color:var(--dark);">#@Model.Id</span>
                </div>
                <div class="d-flex justify-content-between mb-3 pb-3" style="border-bottom:1px solid var(--gray-6);">
                    <span style="color:var(--gray-2);">Status</span>
                    <span style="font-weight:700;color:var(--dark);">@Model.Status</span>
                </div>
                <div class="d-flex justify-content-between mb-3 pb-3" style="border-bottom:1px solid var(--gray-6);">
                    <span style="color:var(--gray-2);">Category</span>
                    <span style="font-weight:700;color:var(--dark);">@Model.CategoryName</span>
                </div>
                <div class="d-flex justify-content-between mb-3 pb-3" style="border-bottom:1px solid var(--gray-6);">
                    <span style="color:var(--gray-2);">Author</span>
                    <span style="font-weight:700;color:var(--dark);">@Model.CreatedByName</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span style="color:var(--gray-2);">Created</span>
                    <span style="font-weight:700;color:var(--dark);">@Model.CreatedDate.ToString("MMM dd")</span>
                </div>
            </div>
        </div>
    </div>
</div>
