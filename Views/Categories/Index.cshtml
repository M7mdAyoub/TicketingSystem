@model List<HelpdeskApp.Models.Category>
@using HelpdeskApp.Data
@{
    ViewData["Title"] = "Categories";
    var lang = Context.Request.Cookies["lang"] ?? "en";
    var token = Html.AntiForgeryToken().ToString();
    var tokenValue = System.Text.RegularExpressions.Regex.Match(token, "value=\"([^\"]+)\"").Groups[1].Value;
}

<div class="page-header">
    <div>
        <h4 class="page-title">@Lang.T("categories", lang)</h4>
        <p class="page-subtitle">@(lang == "ar" ? "تنظيم التذاكر حسب الفئة." : "Organize tickets by category for natural workflow.")</p>
    </div>
    <button type="button" class="btn-coral" onclick="openCategoryModal()">
        <i class="bi bi-plus-lg"></i> @Lang.T("create_new_category", lang)
    </button>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table" id="categoriesTable">
                <thead>
                    <tr>
                        <th>@Lang.T("category", lang)</th>
                        <th>@Lang.T("status", lang)</th>
                        <th>@Lang.T("created_date", lang)</th>
                        <th style="width:100px;">@Lang.T("actions", lang)</th>
                    </tr>
                </thead>
                <tbody id="categoriesBody">
                    @if (Model.Count == 0)
                    {
                        <tr id="emptyRow"><td colspan="4">
                            <div class="empty-state">
                                <i class="bi bi-collection"></i>
                                <p>@(lang == "ar" ? "لم يتم العثور على فئات." : "No categories found yet.")</p>
                            </div>
                        </td></tr>
                    }
                    @foreach (var cat in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div style="width:38px;height:38px;border-radius:50%;background:var(--green-pale);display:flex;align-items:center;justify-content:center;color:var(--green-dark);font-size:0.9rem;flex-shrink:0;">
                                        <i class="bi bi-tag-fill"></i>
                                    </div>
                                    <div>
                                        <div style="font-weight:700;color:var(--dark);font-size:0.9rem;">@cat.Name</div>
                                        <div style="font-size:0.78rem;color:var(--text-light);">ID: @cat.Id</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (cat.IsActive)
                                {
                                    <span class="badge-status badge-active">@Lang.T("active", lang)</span>
                                }
                                else
                                {
                                    <span class="badge-status badge-inactive">@Lang.T("inactive", lang)</span>
                                }
                            </td>
                            <td style="color:var(--text-muted);font-size:0.85rem;">@cat.CreatedDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <form asp-action="ToggleActive" asp-route-id="@cat.Id" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    @if (cat.IsActive)
                                    {
                                        <button type="submit" class="btn-ghost" title="@(lang == "ar" ? "تعطيل" : "Deactivate")" style="color:var(--coral);">
                                            <i class="bi bi-toggle-on" style="font-size:1.2rem;"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn-ghost" title="@(lang == "ar" ? "تفعيل" : "Activate")">
                                            <i class="bi bi-toggle-off" style="font-size:1.2rem;"></i>
                                        </button>
                                    }
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>


<div id="categoryModal" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:9999;backdrop-filter:blur(4px);transition:opacity 0.3s ease;" onclick="if(event.target===this)closeCategoryModal()">
    <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:var(--white);border-radius:var(--radius-xl);padding:36px;width:100%;max-width:460px;box-shadow:var(--shadow-lg);animation:modalIn 0.3s ease;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
            <h3 style="font-family:var(--font-serif);font-weight:800;font-size:1.3rem;color:var(--dark);margin:0;">@Lang.T("create_new_category", lang)</h3>
            <button onclick="closeCategoryModal()" style="background:none;border:none;font-size:1.3rem;color:var(--text-light);cursor:pointer;padding:4px;">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div id="catModalError" style="display:none;padding:10px 16px;background:#fef2f2;border:1px solid #fecaca;border-radius:var(--radius);color:#dc2626;font-size:0.85rem;margin-bottom:16px;">
        </div>

        <form id="catForm" onsubmit="submitCategory(event)">
            <div class="mb-3">
                <label class="form-label">@Lang.T("category_name", lang)</label>
                <input type="text" id="catName" class="form-control" placeholder="@(lang == "ar" ? "مثال: برمجيات، أجهزة، شبكات" : "e.g., Software, Hardware, Network")" required />
            </div>

            <div class="mb-4">
                <div class="form-check form-switch">
                    <input type="checkbox" id="catIsActive" class="form-check-input" role="switch" checked />
                    <label class="form-check-label" style="font-weight:600;">@Lang.T("active", lang)</label>
                </div>
            </div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn-coral" id="catSubmitBtn">
                    <i class="bi bi-check-lg me-1"></i> @Lang.T("create_category", lang)
                </button>
                <button type="button" class="btn-outline-dark" onclick="closeCategoryModal()">@(lang == "ar" ? "إلغاء" : "Cancel")</button>
            </div>
        </form>
    </div>
</div>

<style>
    @@keyframes modalIn {
        from { opacity: 0; transform: translate(-50%, -48%); }
        to { opacity: 1; transform: translate(-50%, -50%); }
    }
</style>

<script>
    var catToken = '@tokenValue';
    var activeTxt = '@Lang.T("active", lang)';
    var inactiveTxt = '@Lang.T("inactive", lang)';

    function openCategoryModal() {
        document.getElementById('categoryModal').style.display = 'block';
        document.getElementById('catName').value = '';
        document.getElementById('catIsActive').checked = true;
        document.getElementById('catModalError').style.display = 'none';
        setTimeout(function() { document.getElementById('catName').focus(); }, 100);
    }

    function closeCategoryModal() {
        document.getElementById('categoryModal').style.display = 'none';
    }

    function submitCategory(e) {
        e.preventDefault();
        var btn = document.getElementById('catSubmitBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="bi bi-hourglass-split me-1"></i> ...';
        document.getElementById('catModalError').style.display = 'none';

        var formData = new FormData();
        formData.append('name', document.getElementById('catName').value);
        formData.append('isActive', document.getElementById('catIsActive').checked);
        formData.append('__RequestVerificationToken', catToken);

        fetch('@Url.Action("CreateAjax", "Categories")', { method: 'POST', body: formData })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    var emptyRow = document.getElementById('emptyRow');
                    if (emptyRow) emptyRow.remove();

                    var tbody = document.getElementById('categoriesBody');
                    var tr = document.createElement('tr');
                    tr.style.animation = 'modalIn 0.4s ease';
                    var badgeClass = data.isActive ? 'badge-active' : 'badge-inactive';
                    var badgeText = data.isActive ? activeTxt : inactiveTxt;
                    tr.innerHTML = `
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <div style="width:38px;height:38px;border-radius:50%;background:var(--green-pale);display:flex;align-items:center;justify-content:center;color:var(--green-dark);font-size:0.9rem;flex-shrink:0;">
                                    <i class="bi bi-tag-fill"></i>
                                </div>
                                <div>
                                    <div style="font-weight:700;color:var(--dark);font-size:0.9rem;">${data.name}</div>
                                    <div style="font-size:0.78rem;color:var(--text-light);">ID: ${data.id}</div>
                                </div>
                            </div>
                        </td>
                        <td><span class="badge-status ${badgeClass}">${badgeText}</span></td>
                        <td style="color:var(--text-muted);font-size:0.85rem;">${data.createdDate}</td>
                        <td><span style="font-size:0.78rem;color:var(--text-light);">↻</span></td>
                    `;
                    tbody.appendChild(tr);
                    closeCategoryModal();
                } else {
                    document.getElementById('catModalError').textContent = data.error;
                    document.getElementById('catModalError').style.display = 'block';
                }
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-check-lg me-1"></i> @Lang.T("create_category", lang)';
            })
            .catch(() => {
                document.getElementById('catModalError').textContent = 'Network error.';
                document.getElementById('catModalError').style.display = 'block';
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-check-lg me-1"></i> @Lang.T("create_category", lang)';
            });
    }

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeCategoryModal();
    });
</script>
