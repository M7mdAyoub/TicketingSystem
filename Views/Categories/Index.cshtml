@model List<HelpdeskApp.Models.Category>
@{
    ViewData["Title"] = "Categories";
}

<div class="page-header">
    <div>
        <h4 class="page-title">Categories</h4>
        <p class="page-subtitle">Organize tickets by category</p>
    </div>
    <a href="@Url.Action("Create")" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> New Category
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Category</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th style="width:100px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr><td colspan="4">
                            <div class="empty-state">
                                <i class="bi bi-collection"></i>
                                <p>No categories found yet.</p>
                            </div>
                        </td></tr>
                    }
                    @foreach (var cat in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div style="width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,#ec4899,#f472b6);display:flex;align-items:center;justify-content:center;color:#fff;font-size:0.9rem;flex-shrink:0;">
                                        <i class="bi bi-tag-fill"></i>
                                    </div>
                                    <div>
                                        <div style="font-weight:700;color:var(--dark);font-size:0.9rem;">@cat.Name</div>
                                        <div style="font-size:0.78rem;color:var(--gray-3);">ID: @cat.Id</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (cat.IsActive)
                                {
                                    <span class="badge badge-active"><i class="bi bi-check-circle me-1"></i>Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-inactive"><i class="bi bi-x-circle me-1"></i>Inactive</span>
                                }
                            </td>
                            <td style="color:var(--gray-2);font-size:0.85rem;">@cat.CreatedDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <form asp-action="ToggleActive" asp-route-id="@cat.Id" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    @if (cat.IsActive)
                                    {
                                        <button type="submit" class="btn btn-sm btn-ghost" title="Deactivate" style="background:rgba(239,68,68,0.08);color:#ef4444;">
                                            <i class="bi bi-toggle-on"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-sm btn-ghost" title="Activate">
                                            <i class="bi bi-toggle-off"></i>
                                        </button>
                                    }
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
