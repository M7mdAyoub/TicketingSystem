@model List<HelpdeskApp.Models.Category>
@using HelpdeskApp.Data
@{
    ViewData["Title"] = "Categories";
    var lang = Context.Request.Cookies["lang"] ?? "en";
    var token = Html.AntiForgeryToken().ToString();
    var tokenValue = System.Text.RegularExpressions.Regex.Match(token, "value=\"([^\"]+)\"").Groups[1].Value;
}

<div class="page-header">
    <div>
        <h4 class="page-title">@Lang.T("categories", lang)</h4>
        <p class="page-subtitle">@(lang == "ar" ? "تنظيم التذاكر حسب الفئة." : "Organize tickets by category for natural workflow.")</p>
    </div>
    <button type="button" class="btn-coral" id="openCategoryModalBtn">
        <i class="bi bi-plus-lg"></i> @Lang.T("create_new_category", lang)
    </button>
</div>


<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table" id="categoriesTable">
                <thead>
                    <tr>
                        <th>@Lang.T("category", lang)</th>
                        <th>@Lang.T("status", lang)</th>
                        <th>@Lang.T("created_date", lang)</th>
                        <th class="ui-st-513467" >@Lang.T("actions", lang)</th>
                    </tr>
                </thead>
                <tbody id="categoriesBody">
                    @if (Model.Count == 0)
                    {
                        <tr id="emptyRow"><td colspan="4">
                            <div class="empty-state">
                                <i class="bi bi-collection"></i>
                                <p>@(lang == "ar" ? "لم يتم العثور على فئات." : "No categories found yet.")</p>
                            </div>
                        </td></tr>
                    }
                    @foreach (var cat in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="ui-st-811086" >
                                        <i class="bi bi-tag-fill"></i>
                                    </div>
                                    <div>
                                        <div class="ui-st-84e012" >@cat.Name</div>
                                        <div class="ui-st-1542fc" >ID: @cat.Id</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (cat.IsActive)
                                {
                                    <span class="badge-status badge-active">@Lang.T("active", lang)</span>
                                }
                                else
                                {
                                    <span class="badge-status badge-inactive">@Lang.T("inactive", lang)</span>
                                }
                            </td>
                            <td class="ui-st-79c561" >@cat.CreatedDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <form class="d-inline" asp-action="ToggleActive" asp-route-id="@cat.Id" method="post" >
                                    @Html.AntiForgeryToken()
                                    @if (cat.IsActive)
                                    {
                                        <button type="submit" class="btn-ghost ui-st-bc7c44" title="@(lang == "ar" ? "تعطيل" : "Deactivate")" >
                                            <i class="bi bi-toggle-on ui-st-ebc214" ></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn-ghost" title="@(lang == "ar" ? "تفعيل" : "Activate")">
                                            <i class="bi bi-toggle-off ui-st-ebc214" ></i>
                                        </button>
                                    }
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>


<div class="ui-st-fed104 modal-overlay-trigger" id="categoryModal">

    <div class="ui-st-baaffb" >
        <div class="ui-st-87d288" >
            <h3 class="ui-st-dcc926" >@Lang.T("create_new_category", lang)</h3>
            <button class="ui-st-5a2acb close-category-modal-btn">

                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="ui-st-36b319" id="catModalError" >
        </div>

        <form id="catForm" data-url="@Url.Action("CreateAjax", "Categories")" data-token="@tokenValue" data-txt-active="@Lang.T("active", lang)" data-txt-inactive="@Lang.T("inactive", lang)">
            <div class="mb-3">
                <label class="form-label">@Lang.T("category_name", lang)</label>
                <input type="text" id="catName" class="form-control" placeholder="@(lang == "ar" ? "مثال: برمجيات، أجهزة، شبكات" : "e.g., Software, Hardware, Network")" required />
            </div>

            <div class="mb-4">
                <div class="form-check form-switch">
                    <input type="checkbox" id="catIsActive" class="form-check-input" role="switch" checked />
                    <label class="form-check-label ui-st-a5d2ba" >@Lang.T("active", lang)</label>
                </div>
            </div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn-coral" id="catSubmitBtn">
                    <i class="bi bi-check-lg me-1"></i> @Lang.T("create_category", lang)
                </button>
                <button type="button" class="btn-outline-dark close-category-modal-btn">@(lang == "ar" ? "إلغاء" : "Cancel")</button>

            </div>
        </form>
    </div>
</div>





@section Styles {
    <link rel="stylesheet" href="~/css/pages/categories.css" />
}

