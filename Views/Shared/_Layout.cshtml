@using Microsoft.AspNetCore.Http
@using HelpdeskApp.Data
@{
    var isAuthenticated = Context.User?.Identity?.IsAuthenticated ?? false;
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var userName = Context.User?.Identity?.Name ?? "User";
    var isLanding = currentController == "Landing";
    var isLogin = currentController == "Account";
    var lang = Context.Request.Cookies["lang"] ?? "en";
    var dir = lang == "ar" ? "rtl" : "ltr";
    var isRtl = lang == "ar";
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NatureDesk</title>
    <link rel="icon" type="image/png" href="~/images/favicon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,800;0,900;1,400;1,700&family=DM+Sans:wght@400;500;600;700&family=Noto+Sans+Arabic:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>
    @if (isAuthenticated && !isLanding && !isLogin)
    {
        <nav class="top-nav">
            <div class="d-flex align-items-center gap-4">
                <a href="@Url.Action("Index", "Home")" class="nav-brand">
                    <img class="ui-st-113f88" src="~/images/logo.png" alt="NatureDesk"  />
                    <span class="nav-brand-text">NatureDesk</span>
                </a>

                <ul class="nav-links">
                    <li><a href="@Url.Action("Index", "Home")" class="@(currentController == "Home" ? "active" : "")">@Lang.T("dashboard", lang)</a></li>
                    <li><a href="@Url.Action("Index", "Tickets")" class="@(currentController == "Tickets" ? "active" : "")">@Lang.T("tickets", lang)</a></li>
                    <li><a href="@Url.Action("Index", "Categories")" class="@(currentController == "Categories" ? "active" : "")">@Lang.T("categories", lang)</a></li>
                    <li><a href="@Url.Action("Index", "Users")" class="@(currentController == "Users" ? "active" : "")">@Lang.T("users", lang)</a></li>
                </ul>
            </div>

            <div class="nav-right">
                <a href="@Url.Action("Switch", "Language", new { lang = isRtl ? "en" : "ar", returnUrl = Context.Request.Path + Context.Request.QueryString })" class="btn-ghost lang-toggle" title="@(isRtl ? "English" : "العربية")">
                    @(isRtl ? "EN" : "ع")
                </a>
                <div class="nav-user">
                    <div class="nav-avatar">
                        @{
                            var parts = userName.Split(' ');
                            var initials = parts.Length >= 2
                                ? parts[0].Substring(0,1).ToUpper() + parts[^1].Substring(0,1).ToUpper()
                                : userName.Substring(0,1).ToUpper();
                        }
                        @initials
                    </div>
                    @userName
                </div>
                <form class="d-inline" asp-action="Logout" asp-controller="Account" method="post" >
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-ghost" title="@Lang.T("sign_out", lang)">
                        <i class="bi bi-box-arrow-right ui-st-e061ff" ></i>
                    </button>
                </form>
            </div>
        </nav>

        <div class="main-content">
            @RenderBody()
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
