@using Microsoft.AspNetCore.Http
@{
    var isAuthenticated = Context.User?.Identity?.IsAuthenticated ?? false;
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var userName = Context.User?.Identity?.Name ?? "User";
    var isLanding = currentController == "Landing";
    var isLogin = currentController == "Account";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NatureDesk</title>
    <link rel="icon" type="image/png" href="~/images/favicon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,800;0,900;1,400;1,700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        /* ========== DESIGN SYSTEM - NATURE DESK ========== */
        :root {
            --green-dark: #0b3d2c;
            --green-deep: #0f4d38;
            --green-mid: #1a6b4a;
            --green-light: #2d8f65;
            --green-pale: #e8f5ee;

            --coral: #e8465a;
            --coral-hover: #d43a4e;
            --coral-light: #fef2f2;
            --coral-glow: rgba(232, 70, 90, 0.12);

            --cream: #faf9f6;
            --white: #ffffff;
            --dark: #1a1a2e;
            --text: #374151;
            --text-muted: #6b7280;
            --text-light: #9ca3af;
            --border: #e5e7eb;
            --border-light: #f3f4f6;

            --font-serif: 'Playfair Display', Georgia, serif;
            --font-sans: 'DM Sans', -apple-system, sans-serif;

            --radius: 12px;
            --radius-lg: 16px;
            --radius-xl: 20px;
            --radius-pill: 50px;

            --shadow-sm: 0 1px 3px rgba(0,0,0,0.04);
            --shadow: 0 2px 12px rgba(0,0,0,0.06);
            --shadow-md: 0 4px 20px rgba(0,0,0,0.08);
            --shadow-lg: 0 8px 32px rgba(0,0,0,0.1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: var(--font-sans);
            background: var(--cream);
            color: var(--text);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        /* ========== TOP NAVIGATION ========== */
        .top-nav {
            background: var(--white);
            border-bottom: 1px solid var(--border);
            padding: 0 32px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
            backdrop-filter: blur(12px);
        }

        .nav-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .nav-brand-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: var(--green-dark);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 1rem;
        }

        .nav-brand-text {
            font-family: var(--font-serif);
            font-weight: 800;
            font-size: 1.2rem;
            color: var(--dark);
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 4px;
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .nav-links a {
            padding: 8px 16px;
            border-radius: var(--radius);
            font-weight: 600;
            font-size: 0.88rem;
            color: var(--text-muted);
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .nav-links a:hover {
            color: var(--dark);
            background: var(--border-light);
        }

        .nav-links a.active {
            color: var(--coral);
            background: var(--coral-light);
        }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .nav-user {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 6px 14px 6px 6px;
            border-radius: var(--radius);
            background: var(--border-light);
            font-weight: 600;
            font-size: 0.85rem;
            color: var(--dark);
        }

        .nav-avatar {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            background: var(--green-dark);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.75rem;
        }

        /* ========== MAIN CONTENT ========== */
        .main-content {
            max-width: 1200px;
            margin: 0 auto;
            padding: 32px 24px;
        }

        /* ========== PAGE HEADERS ========== */
        .page-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 28px;
            gap: 16px;
        }

        .page-title {
            font-family: var(--font-serif);
            font-weight: 800;
            font-size: 1.8rem;
            color: var(--dark);
            margin: 0;
            line-height: 1.2;
        }

        .page-subtitle {
            font-size: 0.9rem;
            color: var(--text-muted);
            margin-top: 4px;
            font-style: italic;
            font-family: var(--font-serif);
        }

        /* ========== BUTTONS ========== */
        .btn-coral {
            background: var(--coral);
            color: #fff;
            border: none;
            padding: 10px 24px;
            border-radius: var(--radius-pill);
            font-weight: 600;
            font-size: 0.88rem;
            cursor: pointer;
            transition: all 0.25s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .btn-coral:hover {
            background: var(--coral-hover);
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 4px 16px rgba(232, 70, 90, 0.3);
        }

        .btn-outline-dark {
            background: transparent;
            color: var(--dark);
            border: 1.5px solid var(--border);
            padding: 10px 24px;
            border-radius: var(--radius-pill);
            font-weight: 600;
            font-size: 0.88rem;
            cursor: pointer;
            transition: all 0.2s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .btn-outline-dark:hover {
            background: var(--dark);
            color: #fff;
            border-color: var(--dark);
        }

        .btn-ghost {
            background: transparent;
            border: none;
            padding: 6px 10px;
            border-radius: 8px;
            cursor: pointer;
            color: var(--text-muted);
            transition: all 0.2s ease;
            font-size: 0.88rem;
        }

        .btn-ghost:hover {
            background: var(--border-light);
            color: var(--dark);
        }

        .btn-sm { padding: 6px 14px; font-size: 0.82rem; }

        /* ========== CARDS ========== */
        .card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            transition: all 0.25s ease;
        }

        .card:hover {
            box-shadow: var(--shadow);
        }

        .card-header {
            padding: 18px 24px;
            border-bottom: 1px solid var(--border-light);
            font-family: var(--font-serif);
            font-weight: 700;
            font-size: 1rem;
            color: var(--dark);
            background: transparent;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .card-body {
            padding: 24px;
        }

        /* ========== TABLES ========== */
        .table {
            width: 100%;
            border-collapse: collapse;
            margin: 0;
        }

        .table thead th {
            padding: 14px 20px;
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-weight: 700;
            color: var(--text-light);
            border-bottom: 1px solid var(--border);
            background: var(--cream);
        }

        .table tbody td {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border-light);
            vertical-align: middle;
            font-size: 0.9rem;
        }

        .table tbody tr {
            transition: background 0.15s ease;
        }

        .table tbody tr:hover {
            background: var(--cream);
        }

        .table tbody tr:last-child td {
            border-bottom: none;
        }

        /* ========== BADGES ========== */
        .badge-status {
            padding: 5px 14px;
            border-radius: var(--radius-pill);
            font-size: 0.76rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .badge-open {
            background: var(--coral-light);
            color: var(--coral);
            border: 1px solid rgba(232, 70, 90, 0.15);
        }

        .badge-inprogress {
            background: #fef9c3;
            color: #92400e;
            border: 1px solid rgba(146, 64, 14, 0.12);
        }

        .badge-closed, .badge-resolved {
            background: var(--green-pale);
            color: var(--green-dark);
            border: 1px solid rgba(11, 61, 44, 0.1);
        }

        .badge-active {
            background: var(--green-pale);
            color: var(--green-mid);
            border: 1px solid rgba(45, 143, 101, 0.15);
        }

        .badge-inactive {
            background: #f3f4f6;
            color: #6b7280;
            border: 1px solid var(--border);
        }

        .badge-new {
            background: var(--coral-light);
            color: var(--coral);
        }

        /* ========== FORMS ========== */
        .form-label {
            font-weight: 600;
            font-size: 0.85rem;
            color: var(--dark);
            margin-bottom: 6px;
        }

        .form-control, .form-select {
            border: 1.5px solid var(--border);
            border-radius: var(--radius);
            padding: 10px 14px;
            font-size: 0.9rem;
            font-family: var(--font-sans);
            transition: all 0.2s ease;
            background: var(--white);
            color: var(--dark);
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--green-mid);
            box-shadow: 0 0 0 3px rgba(45, 143, 101, 0.1);
            outline: none;
        }

        .form-control::placeholder {
            color: var(--text-light);
        }

        /* ========== PAGINATION ========== */
        .pagination {
            display: flex;
            gap: 6px;
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .page-link {
            width: 38px;
            height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.85rem;
            color: var(--text-muted);
            background: var(--white);
            border: 1px solid var(--border);
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .page-link:hover {
            background: var(--cream);
            color: var(--dark);
            border-color: var(--text-light);
        }

        .page-item.active .page-link {
            background: var(--green-dark);
            color: #fff;
            border-color: var(--green-dark);
        }

        /* ========== ALERTS ========== */
        .alert-danger {
            background: var(--coral-light);
            color: var(--coral);
            border: 1px solid rgba(232, 70, 90, 0.15);
            border-radius: var(--radius);
            padding: 12px 16px;
        }

        /* ========== COMMENT ITEMS ========== */
        .comment-bubble {
            padding: 16px 20px;
            border-radius: var(--radius-lg);
            margin-bottom: 16px;
            position: relative;
            max-width: 85%;
        }

        .comment-bubble.left {
            background: var(--cream);
            border: 1px solid var(--border);
            margin-right: auto;
            border-bottom-left-radius: 4px;
        }

        .comment-bubble.right {
            background: var(--coral);
            color: #fff;
            margin-left: auto;
            border-bottom-right-radius: 4px;
        }

        .comment-author {
            font-weight: 700;
            font-size: 0.82rem;
            color: var(--coral);
        }

        .comment-bubble.right .comment-author {
            color: rgba(255,255,255,0.85);
        }

        .comment-date {
            font-size: 0.75rem;
            color: var(--text-light);
            margin-top: 6px;
        }

        .comment-bubble.right .comment-date {
            color: rgba(255,255,255,0.65);
        }

        /* ========== TICKET CARDS ========== */
        .ticket-card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 24px;
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            height: 100%;
            position: relative;
            overflow: hidden;
        }

        .ticket-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            border-radius: 0 4px 4px 0;
        }

        .ticket-card.status-Open::before { background: var(--coral); }
        .ticket-card.status-InProgress::before { background: #f59e0b; }
        .ticket-card.status-Closed::before { background: var(--green-mid); }

        .ticket-card:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-2px);
            border-color: var(--text-light);
        }

        .ticket-card-title {
            font-family: var(--font-serif);
            font-weight: 700;
            font-size: 1.05rem;
            color: var(--dark);
            margin: 8px 0;
            line-height: 1.3;
        }

        .ticket-card-desc {
            font-size: 0.85rem;
            color: var(--text-muted);
            flex: 1;
            margin-bottom: 16px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .ticket-card-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding-top: 14px;
            border-top: 1px solid var(--border-light);
            font-size: 0.8rem;
        }

        /* ========== EMPTY STATE ========== */
        .empty-state {
            text-align: center;
            padding: 48px 20px;
            color: var(--text-light);
        }

        .empty-state i {
            font-size: 3rem;
            margin-bottom: 12px;
            display: block;
        }

        /* ========== STAT CARDS (Dashboard) ========== */
        .stat-card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 24px;
            display: flex;
            align-items: center;
            gap: 16px;
            transition: all 0.25s ease;
        }

        .stat-card:hover {
            box-shadow: var(--shadow);
            transform: translateY(-2px);
        }

        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: var(--radius);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        .stat-value {
            font-family: var(--font-serif);
            font-weight: 800;
            font-size: 1.6rem;
            color: var(--dark);
            line-height: 1;
        }

        .stat-label {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-top: 2px;
        }

        /* ========== LOGIN PAGE ========== */
        .login-page {
            display: flex;
            min-height: 100vh;
        }

        .login-left {
            flex: 1;
            background: linear-gradient(165deg, var(--green-dark) 0%, #0a2e21 100%);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 40px;
            color: #fff;
            position: relative;
            overflow: hidden;
        }

        .login-left::before {
            content: '';
            position: absolute;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            background: rgba(45, 143, 101, 0.12);
            top: -100px;
            right: -100px;
        }

        .login-left::after {
            content: '';
            position: absolute;
            width: 300px;
            height: 300px;
            border-radius: 50%;
            background: rgba(45, 143, 101, 0.08);
            bottom: -50px;
            left: -80px;
        }

        .login-left-title {
            font-family: var(--font-serif);
            font-size: 2.6rem;
            font-weight: 400;
            line-height: 1.25;
            max-width: 400px;
            margin-top: auto;
        }

        .login-left-desc {
            font-size: 0.95rem;
            color: rgba(255,255,255,0.65);
            max-width: 380px;
            margin-top: 20px;
            line-height: 1.6;
        }

        .login-right {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px;
            background: var(--white);
        }

        .login-form-wrap {
            width: 100%;
            max-width: 420px;
        }

        /* ========== LANDING PAGE ========== */
        .landing-nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 48px;
            background: var(--white);
            border-bottom: 1px solid var(--border);
        }

        .landing-hero {
            background: var(--cream);
            padding: 80px 48px 60px;
            position: relative;
        }

        .landing-hero-inner {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            gap: 60px;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 16px;
            background: var(--green-pale);
            color: var(--green-dark);
            border-radius: var(--radius-pill);
            font-size: 0.78rem;
            font-weight: 700;
            margin-bottom: 24px;
        }

        .hero-title {
            font-family: var(--font-serif);
            font-size: 3.4rem;
            font-weight: 800;
            line-height: 1.1;
            color: var(--dark);
            max-width: 550px;
        }

        .hero-title em {
            font-style: italic;
            font-weight: 400;
        }

        .hero-desc {
            font-size: 1.05rem;
            color: var(--text-muted);
            max-width: 480px;
            margin: 24px 0 32px;
            line-height: 1.7;
        }

        .stats-bar {
            background: var(--green-dark);
            border-radius: var(--radius-xl);
            padding: 36px 48px;
            display: flex;
            justify-content: space-around;
            max-width: 1200px;
            margin: -30px auto 60px;
            position: relative;
            z-index: 2;
        }

        .stats-bar-item {
            text-align: center;
            color: #fff;
        }

        .stats-bar-value {
            font-family: var(--font-serif);
            font-size: 1.6rem;
            font-weight: 700;
        }

        .stats-bar-label {
            font-size: 0.78rem;
            color: rgba(255,255,255,0.6);
            margin-top: 4px;
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }

        .features-section {
            max-width: 1200px;
            margin: 0 auto;
            padding: 60px 48px;
        }

        .features-title {
            font-family: var(--font-serif);
            font-size: 2rem;
            font-weight: 800;
            text-align: center;
            color: var(--dark);
            margin-bottom: 8px;
        }

        .features-subtitle {
            text-align: center;
            font-family: var(--font-serif);
            font-style: italic;
            color: var(--text-muted);
            margin-bottom: 48px;
        }

        .feature-card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 32px 28px;
            transition: all 0.3s ease;
        }

        .feature-card:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-4px);
        }

        .feature-icon {
            width: 44px;
            height: 44px;
            border-radius: var(--radius);
            background: var(--green-pale);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--green-dark);
            font-size: 1.1rem;
            margin-bottom: 18px;
        }

        .feature-card h4 {
            font-family: var(--font-serif);
            font-weight: 700;
            font-size: 1.1rem;
            margin-bottom: 10px;
            color: var(--dark);
        }

        .feature-card p {
            font-size: 0.88rem;
            color: var(--text-muted);
            line-height: 1.6;
        }

        .cta-section {
            background: var(--green-dark);
            border-radius: var(--radius-xl);
            max-width: 1200px;
            margin: 20px auto 60px;
            padding: 64px 48px;
            text-align: center;
            color: #fff;
        }

        .cta-title {
            font-family: var(--font-serif);
            font-size: 2.2rem;
            font-weight: 800;
            margin-bottom: 12px;
        }

        .cta-desc {
            color: rgba(255,255,255,0.6);
            margin-bottom: 32px;
        }

        .landing-footer {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 48px;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 40px;
        }

        .footer-col h5 {
            font-weight: 700;
            font-size: 0.85rem;
            margin-bottom: 14px;
            color: var(--dark);
        }

        .footer-col a {
            display: block;
            font-size: 0.85rem;
            color: var(--text-muted);
            text-decoration: none;
            margin-bottom: 8px;
        }

        .footer-col a:hover { color: var(--coral); }

        .footer-bottom {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px 48px;
            border-top: 1px solid var(--border-light);
            display: flex;
            justify-content: space-between;
            font-size: 0.8rem;
            color: var(--text-light);
        }

        /* ========== RESPONSIVE ========== */
        @@media (max-width: 768px) {
            .top-nav { padding: 0 16px; }
            .nav-links { display: none; }
            .main-content { padding: 20px 16px; }
            .page-title { font-size: 1.4rem; }
            .page-header { flex-direction: column; }
            .landing-hero { padding: 40px 20px 40px; }
            .hero-title { font-size: 2rem; }
            .landing-hero-inner { flex-direction: column; }
            .stats-bar { flex-wrap: wrap; gap: 16px; padding: 24px; margin: -20px 16px 40px; }
            .features-section { padding: 40px 20px; }
            .cta-section { margin: 20px 16px 40px; padding: 40px 24px; }
            .landing-footer { padding: 32px 20px; }
            .footer-bottom { padding: 16px 20px; flex-direction: column; gap: 8px; }
            .login-left { display: none; }
            .login-right { padding: 24px; }
            .comment-bubble { max-width: 95%; }
        }

        /* ========== FORM SWITCH ========== */
        .form-check-input:checked {
            background-color: var(--green-mid);
            border-color: var(--green-mid);
        }
    </style>
</head>
<body>
    @if (isAuthenticated && !isLanding && !isLogin)
    {
        <!-- TOP NAVIGATION -->
        <nav class="top-nav">
            <div class="d-flex align-items-center gap-4">
                <a href="@Url.Action("Index", "Home")" class="nav-brand">
                    <img src="~/images/logo.png" alt="NatureDesk" style="width:36px;height:36px;border-radius:10px;object-fit:cover;" />
                    <span class="nav-brand-text">NatureDesk</span>
                </a>

                <ul class="nav-links">
                    <li><a href="@Url.Action("Index", "Home")" class="@(currentController == "Home" ? "active" : "")">Dashboard</a></li>
                    <li><a href="@Url.Action("Index", "Tickets")" class="@(currentController == "Tickets" ? "active" : "")">Tickets</a></li>
                    <li><a href="@Url.Action("Index", "Categories")" class="@(currentController == "Categories" ? "active" : "")">Categories</a></li>
                    <li><a href="@Url.Action("Index", "Users")" class="@(currentController == "Users" ? "active" : "")">Users</a></li>
                </ul>
            </div>

            <div class="nav-right">
                <div class="nav-user">
                    <div class="nav-avatar">
                        @{
                            var parts = userName.Split(' ');
                            var initials = parts.Length >= 2
                                ? parts[0].Substring(0,1).ToUpper() + parts[^1].Substring(0,1).ToUpper()
                                : userName.Substring(0,1).ToUpper();
                        }
                        @initials
                    </div>
                    @userName
                </div>
                <form asp-action="Logout" asp-controller="Account" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-ghost" title="Sign Out">
                        <i class="bi bi-box-arrow-right" style="font-size:1.1rem;"></i>
                    </button>
                </form>
            </div>
        </nav>

        <div class="main-content">
            @RenderBody()
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
