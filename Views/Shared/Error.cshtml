@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <div style="width:80px;height:80px;border-radius:50%;background:rgba(239,68,68,0.1);display:inline-flex;align-items:center;justify-content:center;margin-bottom:20px;">
        <i class="bi bi-exclamation-triangle" style="font-size:2rem;color:var(--danger);"></i>
    </div>
    <h3 class="fw-bold">Something went wrong</h3>
    <p class="text-muted">An unexpected error occurred. Please try again later.</p>
    <a href="@Url.Action("Index", "Home")" class="btn btn-primary mt-2">
        <i class="bi bi-house me-1"></i> Go to Dashboard
    </a>
</div>
