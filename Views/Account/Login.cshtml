@model HelpdeskApp.Models.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "_Layout";
}

<div class="login-page">
    <div class="login-card">
        <div class="text-center mb-4">
            <div style="width:56px;height:56px;border-radius:14px;background:linear-gradient(135deg,#6366f1,#06b6d4);display:inline-flex;align-items:center;justify-content:center;margin-bottom:16px;box-shadow:0 8px 24px rgba(99,102,241,0.35);">
                <i class="bi bi-headset" style="font-size:1.6rem;color:#fff;"></i>
            </div>
            <h3 style="font-weight:800;color:#0f172a;font-size:1.5rem;margin-bottom:4px;">Welcome Back</h3>
            <p style="color:#94a3b8;font-size:0.9rem;">Sign in to your helpdesk account</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger" style="font-size:0.85rem;"></div>
        }

        <form asp-action="Login" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Email" class="form-label" style="font-size:0.85rem;">Email Address</label>
                <div class="input-group">
                    <span class="input-group-text" style="border-radius:8px 0 0 8px;border:1.5px solid #e2e8f0;border-right:none;background:#f8fafc;color:#94a3b8;">
                        <i class="bi bi-envelope"></i>
                    </span>
                    <input asp-for="Email" class="form-control" placeholder="you@example.com" style="border-left:none;" />
                </div>
                <span asp-validation-for="Email" class="text-danger" style="font-size:0.78rem;"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Password" class="form-label" style="font-size:0.85rem;">Password</label>
                <div class="input-group">
                    <span class="input-group-text" style="border-radius:8px 0 0 8px;border:1.5px solid #e2e8f0;border-right:none;background:#f8fafc;color:#94a3b8;">
                        <i class="bi bi-lock"></i>
                    </span>
                    <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" style="border-left:none;" />
                </div>
                <span asp-validation-for="Password" class="text-danger" style="font-size:0.78rem;"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2" style="font-size:0.95rem;font-weight:700;">
                Sign In <i class="bi bi-arrow-right ms-1"></i>
            </button>
        </form>

        <div class="text-center mt-4">

        </div>

        <div class="text-center mt-3">
            <a href="@Url.Action("Index", "Landing")" style="color:#6366f1;font-size:0.85rem;font-weight:600;text-decoration:none;">
                <i class="bi bi-arrow-left me-1"></i> Back to Home
            </a>
        </div>
    </div>
</div>
