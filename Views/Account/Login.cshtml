@model HelpdeskApp.Models.LoginViewModel
@using HelpdeskApp.Data
@{
    ViewData["Title"] = "Sign In";
    Layout = "_Layout";
    var lang = Context.Request.Cookies["lang"] ?? "en";
    var isRtl = lang == "ar";
}

<div class="login-page">
    <div class="login-left">
        <a href="@Url.Action("Index", "Landing")" class="nav-brand ui-st-cb751e" >
            <img class="ui-st-113f88" src="~/images/logo.png" alt="NatureDesk"  />
            <span class="nav-brand-text ui-st-b59271" >NatureDesk</span>
        </a>

        <div class="ui-st-cb751e" >
            <h1 class="login-left-title">
                @Html.Raw(Lang.T("experience_serene", lang))
            </h1>
            <p class="login-left-desc">
                @Lang.T("login_left_desc", lang)
            </p>

            <div class="ui-st-f78c33" >
                <div class="ui-st-cdaa18" >
                    <div class="ui-st-a0d849" >MA</div>
                    <div class="ui-st-0171f4" >FZ</div>
                </div>
                <div>
                    <div class="ui-st-70d5b9" >@Lang.T("teams_count", lang)</div>
                    <div class="ui-st-e2e8f4" >@Lang.T("trust_today", lang)</div>
                </div>
            </div>
        </div>
    </div>

    <div class="login-right">
        <div class="login-form-wrap">
            <div class="ui-st-403b84" >
                <h2 class="ui-st-bc4ebb" >@Lang.T("welcome_back", lang)</h2>
                <a href="@Url.Action("Switch", "Language", new { lang = isRtl ? "en" : "ar", returnUrl = "/Account/Login" })" class="lang-toggle" title="@(isRtl ? "English" : "العربية")">
                    @(isRtl ? "EN" : "ع")
                </a>
            </div>
            <p class="ui-st-31fac4" >@Lang.T("enter_details", lang)</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="alert alert-danger ui-st-73b81e" ></div>
            }

            <form asp-action="Login" asp-controller="Account" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">@Lang.T("email_address", lang)</label>
                    <div class="input-group">
                        <span class="input-group-text ui-st-13e7df" >
                            <i class="bi bi-envelope"></i>
                        </span>
                        <input asp-for="Email" class="form-control ui-st-adb0ac" placeholder="@Lang.T("enter_email", lang)"  />
                    </div>
                    <span asp-validation-for="Email" class="text-danger ui-st-c4ad98" ></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label">@Lang.T("password", lang)</label>
                    <div class="input-group">
                        <span class="input-group-text ui-st-13e7df" >
                            <i class="bi bi-lock"></i>
                        </span>
                        <input asp-for="Password" class="form-control ui-st-adb0ac" type="password" placeholder="••••••••"  />
                    </div>
                    <span asp-validation-for="Password" class="text-danger ui-st-c4ad98" ></span>
                </div>

                <button class="ui-st-65c61b" type="submit" >
                    @Lang.T("sign_in", lang) <i class="bi bi-arrow-right ms-1"></i>
                </button>
            </form>

            <div class="text-center mt-4">
                <small class="ui-st-74de57" >@Lang.T("default_hint", lang) <strong>mohammadayoub@@helpdesk.com</strong> / <strong>Test@@1234</strong></small>
            </div>

            <div class="text-center mt-3 ui-st-3b349f" >
                <a class="ui-st-66a022" href="@Url.Action("Index", "Landing")" >
                    <i class="bi bi-arrow-left me-1"></i> @Lang.T("back_to_home", lang)
                </a>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/login.css" />
}
