@using HelpdeskApp.Data
@{
    ViewData["Title"] = "NatureDesk - Customer Support, Naturally Refined";
    Layout = "_Layout";
    var lang = Context.Request.Cookies["lang"] ?? "en";
    var isRtl = lang == "ar";
}

<nav class="landing-nav">
    <a href="/" class="nav-brand">
        <img class="ui-st-113f88" src="~/images/logo.png" alt="NatureDesk"  />
        <span class="nav-brand-text">NatureDesk</span>
    </a>
    <div class="d-flex align-items-center gap-3">
        <a href="@Url.Action("Switch", "Language", new { lang = isRtl ? "en" : "ar", returnUrl = "/" })" class="lang-toggle" title="@(isRtl ? "English" : "العربية")">
            @(isRtl ? "EN" : "ع")
        </a>
        <a href="@Url.Action("Login", "Account")" class="btn-coral">@Lang.T("sign_in", lang)</a>
    </div>
</nav>

<section class="landing-hero">
    <div class="landing-hero-inner">
        <div class="ui-st-d5e8c5" >
            <div class="hero-badge">
                <i class="bi bi-star-fill ui-st-8f18b4" ></i> @Lang.T("hero_badge", lang)
            </div>
            <h1 class="hero-title">
                @Html.Raw(Lang.T("hero_title", lang))
            </h1>
            <p class="hero-desc">
                @Lang.T("hero_desc", lang)
            </p>
            <div class="d-flex gap-3 flex-wrap">
                <a href="@Url.Action("Login", "Account")" class="btn-coral">
                    <i class="bi bi-leaf me-1"></i> @Lang.T("elevate_desk", lang)
                </a>
                <a href="#features" class="btn-outline-dark">
                    <i class="bi bi-play-circle me-1"></i> @Lang.T("see_workflow", lang)
                </a>
            </div>
        </div>
        <div class="ui-st-ffcc52" >
            <div class="ui-st-68b5d8" >
                <div class="ui-st-4e186f" >
                    <div class="ui-st-b2cd01" ></div>
                    <div class="ui-st-f6af85" ></div>
                    <div class="ui-st-51dc5e" ></div>
                </div>
                <div class="ui-st-16374c" >
                    <div class="ui-st-832e72" >@Lang.T("active_ticket", lang)</div>
                    <div class="ui-st-29d69c" >@(lang == "ar" ? "انقطاع خادم البريد" : "Email server timeout")</div>
                    <div class="ui-st-16318e" >@Lang.T("reported_by", lang) Fatima Al-Zahra • @(lang == "ar" ? "منذ ساعتين" : "2h ago")</div>
                </div>
                <div class="ui-st-06285d" >
                    <div class="ui-st-832e72" >@Lang.T("response_time", lang)</div>
                    <div class="ui-st-8d1293" >1.4 @(lang == "ar" ? "دقيقة" : "min")<span class="ui-st-65e6a5" >↓ 23%</span></div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="stats-bar">
    <div class="stats-bar-item">
        <div class="stats-bar-value">96%</div>
        <div class="stats-bar-label">@Lang.T("resolution_rate", lang)</div>
    </div>
    <div class="stats-bar-item">
        <div class="stats-bar-value ui-st-bc7c44" >4.9/5</div>
        <div class="stats-bar-label">@Lang.T("user_satisfaction", lang)</div>
    </div>
    <div class="stats-bar-item">
        <div class="stats-bar-value">92%</div>
        <div class="stats-bar-label">@Lang.T("sla_compliance", lang)</div>
    </div>
    <div class="stats-bar-item">
        <div class="stats-bar-value">50%</div>
        <div class="stats-bar-label">@Lang.T("ticket_volume", lang)</div>
    </div>
</div>

<section class="features-section" id="features">
    <h2 class="features-title">@Lang.T("crafted_excellence", lang)</h2>
    <p class="features-subtitle">@Lang.T("features_subtitle", lang)</p>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon"><i class="bi bi-intersect"></i></div>
                <h4>@Lang.T("unified_inflow", lang)</h4>
                <p>@Lang.T("unified_desc", lang)</p>
                <a class="ui-st-9d4d8b" href="#" >@Lang.T("learn_more", lang)</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon"><i class="bi bi-cpu"></i></div>
                <h4>@Lang.T("intelligent_roots", lang)</h4>
                <p>@Lang.T("intelligent_desc", lang)</p>
                <a class="ui-st-9d4d8b" href="#" >@Lang.T("learn_more", lang)</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon"><i class="bi bi-graph-up-arrow"></i></div>
                <h4>@Lang.T("organic_growth", lang)</h4>
                <p>@Lang.T("organic_desc", lang)</p>
                <a class="ui-st-9d4d8b" href="#" >@Lang.T("learn_more", lang)</a>
            </div>
        </div>
    </div>
</section>

<section class="cta-section">
    <h2 class="cta-title ui-st-e55f66" >@Html.Raw(Lang.T("cta_title", lang))</h2>
    <p class="cta-desc">@Lang.T("cta_desc", lang)</p>
    <div class="d-flex gap-3 justify-content-center flex-wrap">
        <a href="@Url.Action("Login", "Account")" class="btn-coral ui-st-8466da" >@Lang.T("get_started", lang)</a>
        <a href="#" class="btn-outline-dark ui-st-aca935" >@Lang.T("talk_sales", lang)</a>
    </div>
</section>

<footer class="landing-footer">
    <div class="footer-col">
        <a href="/" class="nav-brand ui-st-53463d" >
            <img class="ui-st-113f88" src="~/images/logo.png" alt="NatureDesk"  />
            <span class="nav-brand-text">NatureDesk</span>
        </a>
        <p class="ui-st-5a2cbd" >@Lang.T("footer_desc", lang)</p>
    </div>
    <div class="footer-col">
        <h5>@Lang.T("product", lang)</h5>
        <a href="#">@Lang.T("ticketing", lang)</a>
        <a href="#">@Lang.T("automation", lang)</a>
        <a href="#">@Lang.T("analytics", lang)</a>
    </div>
    <div class="footer-col">
        <h5>@Lang.T("company", lang)</h5>
        <a href="#">@Lang.T("about_us", lang)</a>
        <a href="#">@Lang.T("our_story", lang)</a>
        <a href="#">@Lang.T("careers", lang)</a>
    </div>
    <div class="footer-col">
        <h5>@Lang.T("support", lang)</h5>
        <a href="#">@Lang.T("help_center", lang)</a>
        <a href="#">@Lang.T("documentation", lang)</a>
        <a href="#">@Lang.T("contact", lang)</a>
    </div>
</footer>

<div class="footer-bottom">
    <span>@Lang.T("all_rights", lang)</span>
    <div class="d-flex gap-3">
        <a class="ui-st-d91d0a" href="#" >@Lang.T("privacy_policy", lang)</a>
        <a class="ui-st-d91d0a" href="#" >@Lang.T("terms_of_service", lang)</a>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/landing.css" />
}
