@{
    ViewData["Title"] = "Helpdesk Pro";
    Layout = "_Layout";
}

<!-- Navigation -->
<div class="landing-body" style="min-height:100vh;">
    <nav class="landing-nav">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-12" style="gap:12px;">
                    <div style="width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,#6366f1,#06b6d4);display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-headset" style="color:#fff;font-size:1.1rem;"></i>
                    </div>
                    <span style="font-weight:800;font-size:1.1rem;color:#fff;">Help<span style="color:#22d3ee;">desk</span> Pro</span>
                </div>
                <a href="@Url.Action("Login", "Account")" class="hero-btn hero-btn-primary" style="padding:10px 24px;font-size:0.9rem;">
                    <i class="bi bi-box-arrow-in-right"></i> Sign In
                </a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-7">
                    <div class="hero-badge">
                        <i class="bi bi-lightning-fill"></i> Fast & Reliable Support System
                    </div>
                    <h1 class="hero-title">
                        Streamline Your<br />
                        <span class="gradient-text">Support Tickets</span><br />
                        Effortlessly
                    </h1>
                    <p class="hero-desc">
                        A modern helpdesk solution designed to help teams track, manage, and resolve 
                        support tickets with speed and clarity. Built for productivity.
                    </p>
                    <div class="d-flex gap-3 flex-wrap">
                        <a href="@Url.Action("Login", "Account")" class="hero-btn hero-btn-primary">
                            Get Started <i class="bi bi-arrow-right"></i>
                        </a>
                        <a href="#features" class="hero-btn hero-btn-outline">
                            <i class="bi bi-play-circle"></i> Learn More
                        </a>
                    </div>

                    <!-- Stats row -->
                    <div class="d-flex gap-5 mt-5 pt-3" style="gap:48px !important;">
                        <div>
                            <div style="font-size:2rem;font-weight:900;color:#fff;">99%</div>
                            <div style="font-size:0.82rem;color:#94a3b8;">Uptime</div>
                        </div>
                        <div>
                            <div style="font-size:2rem;font-weight:900;color:#fff;">&lt;2h</div>
                            <div style="font-size:0.82rem;color:#94a3b8;">Avg Response</div>
                        </div>
                        <div>
                            <div style="font-size:2rem;font-weight:900;color:#fff;">24/7</div>
                            <div style="font-size:0.82rem;color:#94a3b8;">Availability</div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-5 d-none d-lg-block text-center" style="position:relative;z-index:1;">
                    <!-- Floating cards illustration -->
                    <div style="position:relative;">
                        <div style="background:rgba(255,255,255,0.05);backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,0.08);border-radius:20px;padding:32px;max-width:380px;margin:0 auto;">
                            <div class="d-flex align-items-center gap-3 mb-4">
                                <div style="width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,#6366f1,#8b5cf6);display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-ticket-detailed" style="color:#fff;font-size:1.2rem;"></i>
                                </div>
                                <div>
                                    <div style="font-weight:700;font-size:0.95rem;">Ticket #1024</div>
                                    <div style="font-size:0.78rem;color:#94a3b8;">Email not working</div>
                                </div>
                                <span style="margin-left:auto;padding:4px 12px;border-radius:50px;background:rgba(16,185,129,0.15);color:#34d399;font-size:0.75rem;font-weight:600;">Open</span>
                            </div>
                            <div style="height:2px;background:linear-gradient(90deg,#6366f1,#06b6d4,#f472b6);border-radius:2px;margin-bottom:20px;"></div>
                            <div class="d-flex gap-3">
                                <div style="flex:1;padding:14px;border-radius:12px;background:rgba(99,102,241,0.1);text-align:center;">
                                    <div style="font-size:1.3rem;font-weight:800;color:#818cf8;">27</div>
                                    <div style="font-size:0.72rem;color:#94a3b8;">Total</div>
                                </div>
                                <div style="flex:1;padding:14px;border-radius:12px;background:rgba(16,185,129,0.1);text-align:center;">
                                    <div style="font-size:1.3rem;font-weight:800;color:#34d399;">18</div>
                                    <div style="font-size:0.72rem;color:#94a3b8;">Open</div>
                                </div>
                                <div style="flex:1;padding:14px;border-radius:12px;background:rgba(244,114,182,0.1);text-align:center;">
                                    <div style="font-size:1.3rem;font-weight:800;color:#f472b6;">6</div>
                                    <div style="font-size:0.72rem;color:#94a3b8;">InProgress</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="features-section" id="features">
        <div class="container">
            <div class="text-center mb-5">
                <div class="hero-badge mx-auto" style="margin-bottom:16px;">
                    <i class="bi bi-stars"></i> Features
                </div>
                <h2 style="font-size:2.2rem;font-weight:800;margin-bottom:12px;">Everything You Need</h2>
                <p style="color:#94a3b8;font-size:1rem;max-width:500px;margin:0 auto;">
                    Powerful tools to manage your support workflow from start to finish.
                </p>
            </div>

            <div class="row g-4">
                <div class="col-md-6 col-lg-3">
                    <div class="feature-card">
                        <div class="feature-icon" style="background:rgba(99,102,241,0.15);color:#818cf8;">
                            <i class="bi bi-ticket-detailed-fill"></i>
                        </div>
                        <div class="feature-title">Ticket Management</div>
                        <div class="feature-desc">Create, track, and resolve support tickets with a powerful and intuitive interface.</div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div class="feature-card">
                        <div class="feature-icon" style="background:rgba(6,182,212,0.15);color:#22d3ee;">
                            <i class="bi bi-chat-dots-fill"></i>
                        </div>
                        <div class="feature-title">Live Comments</div>
                        <div class="feature-desc">Collaborate with your team through ticket comments with real-time updates.</div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div class="feature-card">
                        <div class="feature-icon" style="background:rgba(244,114,182,0.15);color:#f472b6;">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <div class="feature-title">User Management</div>
                        <div class="feature-desc">Manage users with activation control and secure authentication.</div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3">
                    <div class="feature-card">
                        <div class="feature-icon" style="background:rgba(245,158,11,0.15);color:#fbbf24;">
                            <i class="bi bi-search"></i>
                        </div>
                        <div class="feature-title">Smart Search</div>
                        <div class="feature-desc">Find tickets instantly with search, filters, and category-based organization.</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="landing-footer">
        <div class="container">
            <p class="mb-0">&copy; @DateTime.Now.Year Helpdesk Pro — Built with ASP.NET Core MVC & ADO.NET</p>
        </div>
    </footer>
</div>
